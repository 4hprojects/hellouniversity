# HelloUniversity production environment baseline
# Copy this file to your deployment secret manager/.env for production.

NODE_ENV=production
PORT=3000

# Required core config (set real values)
MONGODB_URI=
MONGODB_DB_NAME=myDatabase
SESSION_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

SENDGRID_API_KEY=
SENDER_EMAIL=

GOOGLE_API_KEY=
GOOGLE_SPREADSHEET_ID_ATTENDANCE=
GOOGLE_TYPE=
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_AUTH_URI=
GOOGLE_TOKEN_URI=
GOOGLE_AUTH_PROVIDER_X509_CERT_URL=
GOOGLE_CLIENT_X509_CERT_URL=
GOOGLE_UNIVERSE_DOMAIN=

# Captcha
DISABLE_CAPTCHA=false
RECAPTCHA_SITE_KEY=
SECRET_KEY=

# Explicit production hardening (required when NODE_ENV=production)
TRUST_PROXY=1
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=.hellouniversity.online
SESSION_MAX_AGE_MS=7200000

ENABLE_CSP=true
CSP_REPORT_ONLY=true

# Optional feature flags
ACTIVITY_RANDOM_REQUIRE_STAFF=true
