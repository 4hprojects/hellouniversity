<%
  const resolvedCanonicalUrl = canonicalUrl || 'https://hellouniversity.online/';
  const resolvedExtraHead = typeof extraHead === 'string' ? extraHead : '';
  const protectedNoindexPrefixes = [
    '/admin',
    '/approval-pending',
    '/attendance',
    '/activities',
    '/classes',
    '/classrush',
    '/crfv',
    '/dashboard',
    '/grades',
    '/login',
    '/quizzes',
    '/reset-password',
    '/signup',
    '/teacher'
  ];
  const protectedNoindexExactPaths = new Set([
    '/confirm-email',
    '/resend-confirmation',
    '/search'
  ]);
  let shouldAutoNoindex = false;

  try {
    const canonicalPath = new URL(resolvedCanonicalUrl, 'https://hellouniversity.online').pathname;
    shouldAutoNoindex =
      protectedNoindexExactPaths.has(canonicalPath) ||
      protectedNoindexPrefixes.some((prefix) => canonicalPath === prefix || canonicalPath.startsWith(`${prefix}/`));
  } catch (_error) {
    shouldAutoNoindex = false;
  }

  const hasRobotsMeta = /<meta\b[^>]*name=["']robots["']/i.test(resolvedExtraHead);
%>
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-X5E3N182NE"></script>
  <script nonce="<%= locals.nonce || '' %>">
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-X5E3N182NE');
  </script>

  <link rel="canonical" href="<%= resolvedCanonicalUrl %>">
  <meta name="google-adsense-account" content="ca-pub-4537208011192461">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= description || 'HelloUniversity is not a university itself. It is a digital academic platform designed to support school and higher education workflows such as classes, assessments, communication, and learning management.' %>">
  <title><%= title || 'HelloUniversity - Digital Academic Platform' %></title>
  <%- include('./favicon') %>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
  <link rel="stylesheet" href="/css/ustyles.css">
  <link rel="stylesheet" href="/css/app_nav.css">
  <% if (typeof includeAppTheme === 'undefined' || includeAppTheme !== false) { %>
    <link rel="stylesheet" href="/css/app_theme.css">
  <% } %>

  <% if (Array.isArray(stylesheets)) { %>
    <% stylesheets.forEach(function(href) { %>
      <link rel="stylesheet" href="<%= href %>">
    <% }) %>
  <% } %>

  <script src="/js/uscripts.js" defer></script>

  <% if (shouldAutoNoindex && !hasRobotsMeta) { %>
    <meta name="robots" content="noindex, follow">
  <% } %>
  <%- resolvedExtraHead %>
</head>
