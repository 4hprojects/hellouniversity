<!-- Section 5: Formulas -->
<section class="mt-10">
    <h2 class="text-2xl font-semibold text-green-700 mb-4">Must-Know Google Sheets Formulas</h2>
    <p class="mb-6">These 10 formulas handle 90% of spreadsheet tasks. Bookmark this section!</p>

    <div class="overflow-x-auto">
        <table class="min-w-full bg-white rounded-lg overflow-hidden mb-6">
            <thead class="bg-gray-100">
                <tr>
                    <th class="py-3 px-4 text-left">Formula</th>
                    <th class="py-3 px-4 text-left">What It Does</th>
                    <th class="py-3 px-4 text-left">Real-World Example</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                <!-- SUM -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-blue-50 text-blue-700">=SUM(A1:A10)</td>
                    <td class="py-3 px-4">Adds values in a range</td>
                    <td class="py-3 px-4">Total quarterly sales</td>
                </tr>
                <!-- AVERAGE -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-green-50 text-green-700">=AVERAGE(B1:B10)</td>
                    <td class="py-3 px-4">Calculates the average</td>
                    <td class="py-3 px-4">Average monthly expenses</td>
                </tr>
                <!-- MAX -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-yellow-50 text-yellow-700">=MAX(C1:C10)</td>
                    <td class="py-3 px-4">Finds the highest value</td>
                    <td class="py-3 px-4">Identify the top score</td>
                </tr>
                <!-- MIN -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-orange-50 text-orange-700">=MIN(D1:D10)</td>
                    <td class="py-3 px-4">Finds the lowest value</td>
                    <td class="py-3 px-4">Find the smallest order amount</td>
                </tr>
                <!-- COUNT -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-purple-50 text-purple-700">=COUNT(E1:E10)</td>
                    <td class="py-3 px-4">Counts cells with numbers</td>
                    <td class="py-3 px-4">Count total sales transactions</td>
                </tr>
                <!-- IF -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-pink-50 text-pink-700">=IF(F1>100, "High", "Low")</td>
                    <td class="py-3 px-4">Performs conditional logic</td>
                    <td class="py-3 px-4">Flag high or low sales</td>
                </tr>
                <!-- VLOOKUP -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-green-50 text-green-700">=VLOOKUP("Item",A1:B10,2,FALSE)</td>
                    <td class="py-3 px-4">Finds matching data</td>
                    <td class="py-3 px-4">Pull product prices from inventory</td>
                </tr>
                <!-- CONCATENATE -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-blue-50 text-blue-700">=CONCATENATE(G1, " ", H1)</td>
                    <td class="py-3 px-4">Combines text values</td>
                    <td class="py-3 px-4">Join first and last names</td>
                </tr>
                <!-- LEFT/RIGHT/MID -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-teal-50 text-teal-700">=LEFT(I1, 3)</td>
                    <td class="py-3 px-4">Extracts the first 3 characters</td>
                    <td class="py-3 px-4">Get area codes from phone numbers</td>
                </tr>
                <!-- TRIM -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-gray-50 text-gray-700">=TRIM(J1)</td>
                    <td class="py-3 px-4">Removes extra spaces</td>
                    <td class="py-3 px-4">Clean messy data</td>
                </tr>
                <!-- COUNTIF -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-purple-50 text-purple-700">=COUNTIF(K1:K10, ">100")</td>
                    <td class="py-3 px-4">Counts cells meeting criteria</td>
                    <td class="py-3 px-4">Track high-value transactions</td>
                </tr>
                <!-- SUMIF -->
                <tr>
                    <td class="py-3 px-4 font-mono bg-red-50 text-red-700">=SUMIF(L1:L10, "<100", L1:L10)</td>
                    <td class="py-3 px-4">Sums cells meeting criteria</td>
                    <td class="py-3 px-4">Sum low-cost orders</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

