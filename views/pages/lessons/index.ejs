<%
  const currentUser = (typeof user !== 'undefined' && user) ? user : null;
  const currentRole = (typeof role !== 'undefined' && role) ? role : (currentUser ? currentUser.role : null);
  const isAuthenticated = Boolean(currentUser || currentRole);
  const lessonSections = Array.isArray(sections) ? sections : [];
  const startPathItems = Array.isArray(startPaths) ? startPaths : [];
  const lessonFilterOptions = Array.isArray(lessonFilters) ? lessonFilters : [];
  const supportItems = Array.isArray(supportResources) ? supportResources : [];
  const stats = lessonStats || { trackCount: 0, lessonCount: 0, professionalTrackCount: 0 };

  let primaryWorkspace = { href: '/login', label: 'Sign In', icon: 'login' };

  if (currentRole === 'teacher') {
    primaryWorkspace = { href: '/teacher/dashboard', label: 'Open Teacher Workspace', icon: 'co_present' };
  } else if (currentRole === 'teacher_pending') {
    primaryWorkspace = { href: '/approval-pending', label: 'Account Status', icon: 'hourglass_top' };
  } else if (currentRole === 'admin') {
    primaryWorkspace = { href: '/admin_dashboard', label: 'Open Admin Workspace', icon: 'admin_panel_settings' };
  } else if (currentRole === 'manager') {
    primaryWorkspace = { href: '/crfv', label: 'Open CRFV Workspace', icon: 'volunteer_activism' };
  } else if (isAuthenticated) {
    primaryWorkspace = { href: '/dashboard', label: 'Open Student Workspace', icon: 'dashboard' };
  }

  const lessonsMenuLinks = [
    { href: '#lessonsHero', label: 'Overview', icon: 'dashboard' },
    { href: '#lessonsStart', label: 'Start Here', icon: 'school' },
    { href: '#lessonsCatalog', label: 'Catalog', icon: 'menu_book' },
    ...(supportItems.length ? [{ href: '#lessonsSupport', label: 'Support', icon: 'tips_and_updates' }] : [])
  ];
%>

<section class="lessons-shell">
  <aside class="lessons-sidebar lessons-card">
    <div class="lessons-sidebar-header">
      <div>
        <p class="lessons-eyebrow">Learning Hub</p>
        <h2>Lessons Menu</h2>
        <p class="lessons-meta">Use one starting path, then browse the lesson-track catalog. Extra reading stays optional.</p>
      </div>
    </div>

    <nav class="lessons-sidebar-nav" aria-label="Lessons page sections">
      <% lessonsMenuLinks.forEach(function(item) { %>
        <a href="<%= item.href %>" class="lessons-sidebar-link" title="<%= item.label %>" aria-label="<%= item.label %>">
          <span class="material-icons" aria-hidden="true"><%= item.icon %></span>
          <span class="lessons-sidebar-link-label"><%= item.label %></span>
        </a>
      <% }) %>
    </nav>

    <div class="lessons-sidebar-status">
      <article class="lessons-status-card">
        <span class="material-icons" aria-hidden="true">library_books</span>
        <div>
          <strong><%= stats.trackCount %> lesson tracks</strong>
          <p>Browse one lesson-first catalog instead of a mixed list of tracks, books, and side content.</p>
        </div>
      </article>
      <article class="lessons-status-card">
        <span class="material-icons" aria-hidden="true">school</span>
        <div>
          <strong><%= stats.lessonCount %> public lessons</strong>
          <p>Start with an on-ramp below, then move into the full track library when you know your goal.</p>
        </div>
      </article>
    </div>
  </aside>

  <div class="lessons-main">
    <section id="lessonsHero" class="lessons-card lessons-hero">
      <div class="lessons-hero-copy">
        <p class="lessons-eyebrow">Structured Learning Paths</p>
        <h1>Choose a lesson path quickly, then move straight into the right track.</h1>
        <p class="lessons-subcopy">
          <%= brandName || 'HelloUniversity' %> keeps this page focused on lesson tracks first: pick a starting point, browse the catalog, and use extra support only when you need it.
        </p>
        <div class="lessons-hero-actions">
          <a href="#lessonsStart" class="lessons-btn lessons-btn-primary">Where should I start?</a>
          <a href="#lessonsCatalog" class="lessons-btn lessons-btn-secondary">What tracks exist?</a>
          <a href="<%= primaryWorkspace.href %>" class="lessons-btn lessons-btn-secondary"><%= primaryWorkspace.label %></a>
        </div>
      </div>

      <div class="lessons-hero-stack">
        <article class="lessons-mini-panel">
          <p class="lessons-mini-label">Start with a path</p>
          <p class="lessons-mini-value">Pick your goal first</p>
          <p class="lessons-meta">Use the entry paths below if you are new and do not want to scan every track manually.</p>
        </article>
        <article class="lessons-mini-panel">
          <p class="lessons-mini-label">Then browse the catalog</p>
          <p class="lessons-mini-value"><%= stats.trackCount %> tracks</p>
          <p class="lessons-meta">The full catalog stays focused on public lesson tracks only, with filters for foundations and programming.</p>
        </article>
      </div>
    </section>

    <section id="lessonsStart" class="lessons-card lessons-panel">
      <div class="lessons-section-heading">
        <p class="lessons-eyebrow">Where should I start?</p>
        <h2>Choose the path that matches your immediate goal</h2>
        <p class="lessons-meta">These entry points are for first-time visitors who want one clear starting recommendation before browsing the full catalog.</p>
      </div>
      <div class="lessons-featured-grid">
        <% startPathItems.forEach(function(item) { %>
          <article class="lessons-featured-card">
            <div class="lessons-featured-icon">
              <span class="material-icons" aria-hidden="true"><%= item.icon %></span>
            </div>
            <p class="lessons-featured-track"><%= item.track %></p>
            <h3><a href="<%= item.href %>"><%= item.title %></a></h3>
            <p><%= item.description %></p>
            <a href="<%= item.href %>" class="lessons-inline-link">Open path</a>
          </article>
        <% }) %>
      </div>
    </section>

    <section id="lessonsCatalog" class="lessons-card lessons-panel">
      <div class="lessons-section-heading">
        <p class="lessons-eyebrow">What tracks exist?</p>
        <h2>Browse the full lesson-track catalog</h2>
        <p class="lessons-meta">Search or filter the library once you know whether you want foundations, productivity, or programming-oriented lesson paths.</p>
      </div>

      <div class="lessons-filter-toolbar">
        <div class="lessons-search-field">
          <label for="lessonsCatalogSearch">Search tracks or lesson titles</label>
          <input
            id="lessonsCatalogSearch"
            class="lessons-search-input"
            type="search"
            placeholder="Search Python, Gmail, DSA, Node.js..."
            autocomplete="off">
        </div>
        <button id="lessonsClearFilters" type="button" class="lessons-btn lessons-btn-secondary">Clear Filters</button>
      </div>

      <div class="lessons-filter-bar" role="toolbar" aria-label="Lesson track filters">
        <% lessonFilterOptions.forEach(function(filter, index) { %>
          <button
            type="button"
            class="lessons-filter-chip <%= index === 0 ? 'lessons-filter-chip-active' : '' %>"
            data-lessons-filter="<%= filter.value %>"
            aria-pressed="<%= index === 0 ? 'true' : 'false' %>">
            <%= filter.label %>
          </button>
        <% }) %>
      </div>

      <p id="lessonsResultsLabel" class="lessons-results-label" aria-live="polite">
        Showing all <%= stats.trackCount %> tracks
      </p>

      <div class="lessons-section-stack">
        <% lessonSections.forEach(function(section) { %>
          <section class="lessons-catalog-section" data-track-section>
            <div class="lessons-catalog-section-header">
              <div>
                <p class="lessons-eyebrow"><%= section.eyebrow %></p>
                <h3><%= section.title %></h3>
                <p class="lessons-meta"><%= section.description %></p>
              </div>
              <span class="lessons-section-count" data-section-count><%= section.tracks.length %> tracks</span>
            </div>

            <div class="lessons-track-grid">
              <% section.tracks.forEach(function(track) { %>
                <article
                  class="lessons-track-card"
                  data-track-card
                  data-domain="<%= track.domain %>"
                  data-search="<%= track.searchText %>">
                  <div class="lessons-track-card-top">
                    <div class="lessons-track-icon">
                      <span class="material-icons" aria-hidden="true"><%= track.icon %></span>
                    </div>
                    <div class="lessons-track-headings">
                      <p class="lessons-track-domain"><%= track.domainLabel %></p>
                      <h4><%= track.title %></h4>
                    </div>
                    <span class="lessons-track-count"><%= track.lessonCount %> lessons</span>
                  </div>

                  <p class="lessons-track-summary"><%= track.summary %></p>

                  <div class="lessons-track-meta">
                    <span class="lessons-track-level"><%= track.level %></span>
                    <a href="<%= track.lessons[0].href %>" class="lessons-inline-link">
                      Start with <%= track.lessons[0].title %>
                    </a>
                  </div>

                  <ul class="lessons-track-links">
                    <% track.previewLessons.forEach(function(lesson) { %>
                      <li><a href="<%= lesson.href %>"><%= lesson.title %></a></li>
                    <% }) %>
                  </ul>

                  <% if (track.remainingLessonCount > 0) { %>
                    <p class="lessons-track-more">+ <%= track.remainingLessonCount %> more lesson<%= track.remainingLessonCount === 1 ? '' : 's' %> in this track</p>
                  <% } %>
                </article>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </div>

      <div id="lessonsEmptyState" class="lessons-empty-state" hidden>
        <span class="material-icons" aria-hidden="true">search_off</span>
        <h3>No matching tracks</h3>
        <p>Try a broader search or reset the filter chips to show the full catalog again.</p>
      </div>
    </section>

    <% if (supportItems.length) { %>
      <section id="lessonsSupport" class="lessons-card lessons-panel lessons-support-strip">
        <div class="lessons-section-heading">
          <p class="lessons-eyebrow">Need extra support?</p>
          <h2>Use these support resources after you choose a lesson path</h2>
          <p class="lessons-meta">These links stay available for study habits and companion reading, but they remain secondary to the lesson catalog.</p>
        </div>

        <div class="lessons-support-grid">
          <% supportItems.forEach(function(item) { %>
            <article class="lessons-support-card">
              <div class="lessons-support-card-top">
                <div class="lessons-track-icon">
                  <span class="material-icons" aria-hidden="true"><%= item.icon %></span>
                </div>
                <div>
                  <p class="lessons-featured-track"><%= item.label %></p>
                  <h3><a href="<%= item.href %>"><%= item.title %></a></h3>
                </div>
              </div>
              <p><%= item.description %></p>
              <a href="<%= item.href %>" class="lessons-inline-link">Open resource</a>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>
  </div>
</section>
