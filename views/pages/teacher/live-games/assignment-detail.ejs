<%- include('../../../partials/head', {
  title: title,
  description: description,
  canonicalUrl: canonicalUrl,
  stylesheets: stylesheets
}) %>
<body data-game-id="<%= gameId %>" data-assignment-id="<%= assignmentId %>">
  <%- include('../../../partials/nav', {
    user: (typeof user !== 'undefined' ? user : undefined),
    role: (typeof role !== 'undefined' ? role : undefined),
    siteName: 'HelloUniversity'
  }) %>

  <div class="lg-page">
    <div class="lg-page-header">
      <div>
        <h1>Self-Paced Assignment</h1>
        <p class="lg-page-tagline" id="lgAssignmentTagline">Loading self-paced ClassRush assignment detail...</p>
      </div>
      <div class="lg-card-actions">
        <a href="/teacher/live-games/<%= gameId %>/reports" class="lg-btn lg-btn-secondary">
          <span class="material-icons">arrow_back</span> Back to Reports
        </a>
      </div>
    </div>

    <div id="lgAssignmentSummary" class="lg-grid" style="margin-bottom:1.25rem;">
      <div class="lg-empty" style="grid-column: 1 / -1">
        <span class="material-icons">assignment</span>
        <p>Loading summary...</p>
      </div>
    </div>

    <section class="lg-card" style="margin-bottom:1.25rem;">
      <h2 class="lg-card-title">Question Analytics</h2>
      <div id="lgAssignmentQuestions" class="lg-report-stack">
        <p class="lg-page-tagline">Loading assignment analytics...</p>
      </div>
    </section>

    <section class="lg-card">
      <h2 class="lg-card-title">Student Results</h2>
      <div id="lgAssignmentStudents" class="lg-report-stack">
        <p class="lg-page-tagline">Loading student results...</p>
      </div>
    </section>
  </div>

  <div id="lgToast" class="lg-toast"></div>

  <script src="/js/liveGames/teacherGameReports.js"></script>
  <script nonce="<%= locals.nonce || '' %>">teacherGameReports.initAssignmentDetail();</script>
</body>
</html>
