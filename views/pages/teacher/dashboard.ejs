<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head', {
  title: 'Teacher Dashboard | HelloUniversity',
  description: 'Teacher workspace for classes, quizzes, ClassRush, and current teaching activity.',
  canonicalUrl: 'https://hellouniversity.online/teacher/dashboard',
  stylesheets: ['/css/teacher_quizzes.css']
}) %>
<body class="teacher-dashboard-page">
  <%- include('../../partials/nav', { user, role, siteName: 'HelloUniversity' }) %>

  <main class="teacher-shell">
    <% if (typeof pendingVerification !== 'undefined' && pendingVerification) { %>
      <% if (pendingVerification.docSubmitted) { %>
        <div class="teacher-pending-banner teacher-pending-banner-info" role="status">
          <span class="material-icons" aria-hidden="true">hourglass_top</span>
          <div>
            <strong>Account approval pending.</strong>
            Your verification document has been submitted and is awaiting admin review. You have full access in the meantime.
            <a href="/approval-pending" class="teacher-pending-banner-link">View submission &rarr;</a>
          </div>
        </div>
      <% } else { %>
        <div class="teacher-pending-banner teacher-pending-banner-warning" role="alert">
          <span class="material-icons" aria-hidden="true">warning</span>
          <div>
            <strong>Action required: Upload your verification document.</strong>
            To get your account approved, please submit a copy of your ID or institutional affiliation document.
            <a href="/approval-pending" class="teacher-pending-banner-link">Upload now &rarr;</a>
          </div>
        </div>
      <% } %>
    <% } %>
    <div id="teacherDashboardLayout" class="teacher-dashboard-layout">
      <aside id="teacherDashboardSidebar" class="teacher-card teacher-dashboard-sidebar">
        <div class="teacher-dashboard-sidebar-header">
          <div>
            <p class="teacher-eyebrow">Quick Links</p>
            <h2>Teacher Menu</h2>
          </div>
          <button
            id="teacherDashboardSidebarToggle"
            type="button"
            class="teacher-dashboard-sidebar-toggle"
            aria-expanded="true"
            aria-label="Collapse teacher menu"
            title="Collapse teacher menu"
            aria-controls="teacherDashboardSidebarContent"
          >
            <span id="teacherDashboardSidebarToggleIcon" aria-hidden="true">&larr;</span>
          </button>
        </div>
        <div id="teacherDashboardSidebarContent" class="teacher-dashboard-sidebar-content">
          <nav aria-label="Teacher dashboard sections" class="teacher-dashboard-nav">
            <a href="#teacherOverview" class="teacher-dashboard-nav-link" title="Overview" aria-label="Overview">
              <span class="material-icons" aria-hidden="true">dashboard</span>
              <span class="teacher-dashboard-nav-label">Overview</span>
            </a>
            <a href="#teacherClassesSection" class="teacher-dashboard-nav-link" title="Classes" aria-label="Classes">
              <span class="material-icons" aria-hidden="true">school</span>
              <span class="teacher-dashboard-nav-label">Classes</span>
            </a>
            <a href="#teacherQuizzesSection" class="teacher-dashboard-nav-link" title="Quizzes" aria-label="Quizzes">
              <span class="material-icons" aria-hidden="true">quiz</span>
              <span class="teacher-dashboard-nav-label">Quizzes</span>
            </a>
            <a href="/teacher/live-games" class="teacher-dashboard-nav-link" title="ClassRush" aria-label="ClassRush">
              <span class="material-icons" aria-hidden="true">sports_esports</span>
              <span class="teacher-dashboard-nav-label">ClassRush</span>
            </a>
          </nav>
          <div class="teacher-dashboard-shortcuts">
            <a href="/teacher/classes" class="teacher-dashboard-shortcut teacher-dashboard-shortcut-primary" title="Open Classes" aria-label="Open Classes">
              <span class="material-icons" aria-hidden="true">class</span>
              <span class="teacher-dashboard-nav-label">Classes</span>
            </a>
            <a href="/teacher/quizzes" class="teacher-dashboard-shortcut" title="Quiz Dashboard" aria-label="Quiz Dashboard">
              <span class="material-icons" aria-hidden="true">fact_check</span>
              <span class="teacher-dashboard-nav-label">Quiz Dashboard</span>
            </a>
            <a href="/teacher/quizzes/new" class="teacher-dashboard-shortcut" title="Create Quiz" aria-label="Create Quiz">
              <span class="material-icons" aria-hidden="true">add_circle</span>
              <span class="teacher-dashboard-nav-label">Create Quiz</span>
            </a>
            <a href="/teacher/live-games/new" class="teacher-dashboard-shortcut" title="Create ClassRush" aria-label="Create ClassRush">
              <span class="material-icons" aria-hidden="true">sports_esports</span>
              <span class="teacher-dashboard-nav-label">Create ClassRush</span>
            </a>
          </div>
        </div>
      </aside>

      <div class="teacher-dashboard-main">
        <section class="teacher-hero teacher-dashboard-hero">
          <div>
            <p class="teacher-eyebrow">Teacher Workspace</p>
            <h1>Hello, <span id="teacherDisplayName">Teacher</span>.</h1>
            <p class="teacher-subcopy">Use this dashboard to manage classes, build quizzes, and host ClassRush live games from one supported workspace.</p>
            <div class="teacher-hero-meta">
              <span id="teacherRolePill" class="teacher-badge teacher-badge-soft">teacher</span>
              <% if (typeof role !== 'undefined' && role === 'teacher') { %>
                <span class="teacher-badge teacher-badge-verified">
                  <span class="material-icons" aria-hidden="true">verified</span>Verified
                </span>
              <% } %>
              <span id="teacherIdLine" class="teacher-meta">Loading teacher profile...</span>
            </div>
          </div>
          <div class="teacher-hero-actions">
            <a href="/teacher/classes" class="teacher-btn teacher-btn-primary">Open Classes</a>
            <a href="/teacher/quizzes/new" class="teacher-btn teacher-btn-primary">Create Quiz</a>
            <a href="/teacher/live-games/new" class="teacher-btn teacher-btn-primary">Create ClassRush</a>
            <a href="/teacher/quizzes" class="teacher-btn teacher-btn-secondary">Open Quiz Dashboard</a>
          </div>
        </section>

        <section id="teacherOverview" class="teacher-dashboard-section">
          <div class="teacher-section-heading">
            <h2>Teaching Overview</h2>
            <p>Snapshot of your classes, quizzes, and current workload.</p>
          </div>
          <div class="teacher-kpi-grid">
            <article class="teacher-card">
              <p class="teacher-kpi-label">Classes</p>
              <p id="teacherClassCount" class="teacher-kpi-value">-</p>
              <p class="teacher-meta">Classes currently assigned to you.</p>
            </article>
            <article class="teacher-card">
              <p class="teacher-kpi-label">Students</p>
              <p id="teacherStudentCount" class="teacher-kpi-value">-</p>
              <p class="teacher-meta">Combined enrolled students across your classes.</p>
            </article>
            <article class="teacher-card">
              <p class="teacher-kpi-label">Active Quizzes</p>
              <p id="teacherActiveQuizCount" class="teacher-kpi-value">-</p>
              <p class="teacher-meta">Currently active quizzes from the existing quiz API.</p>
            </article>
            <article class="teacher-card">
              <p class="teacher-kpi-label">Draft / Inactive</p>
              <p id="teacherDraftQuizCount" class="teacher-kpi-value">-</p>
              <p class="teacher-meta">Quizzes not active yet and likely still being prepared.</p>
            </article>
          </div>
        </section>

        <section class="teacher-dashboard-grid">
          <article id="teacherClassesSection" class="teacher-card teacher-panel">
            <div class="teacher-panel-header">
              <div>
                <p class="teacher-eyebrow">Classes</p>
                <h2>Your Classes</h2>
              </div>
              <a href="/teacher/classes" class="teacher-inline-link">Open class management</a>
            </div>
            <div id="teacherClassList" class="teacher-list-stack">
              <p class="teacher-empty-state">Loading classes...</p>
            </div>
          </article>

          <article id="teacherQuizzesSection" class="teacher-card teacher-panel">
            <div class="teacher-panel-header">
              <div>
                <p class="teacher-eyebrow">Quizzes</p>
                <h2>Recent Quizzes</h2>
              </div>
              <a href="/teacher/quizzes" class="teacher-inline-link">Open all quizzes</a>
            </div>
            <div id="teacherQuizList" class="teacher-list-stack">
              <p class="teacher-empty-state">Loading quizzes...</p>
            </div>
          </article>
        </section>
      </div>
    </div>
  </main>

  <script src="/js/teacherDashboard.js"></script>
</body>
</html>
