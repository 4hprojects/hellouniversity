<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head', {
  title,
  description,
  canonicalUrl,
  stylesheets
}) %>
<body class="auth-page auth-page-login">
  <%- include('../../partials/nav', {
    user: (typeof user !== 'undefined' ? user : undefined),
    role: (typeof role !== 'undefined' ? role : undefined),
    siteName: 'HelloUniversity'
  }) %>

  <main class="auth-shell">
    <section class="auth-hero-card auth-login-panels">
      <div class="auth-copy auth-login-panel auth-login-panel-copy">
        <p class="auth-eyebrow">Sign In</p>
        <h1>Access the HelloUniversity platform with your email.</h1>
        <p class="auth-subcopy">Use your confirmed email address and password to continue to the right workspace for your role in the platform.</p>
        <ul class="auth-feature-list" aria-label="Authentication highlights">
          <li>Email-only HelloUniversity login</li>
          <li>Role-aware dashboard redirect</li>
          <li>Password reset if you get locked out</li>
        </ul>
      </div>

      <form id="loginForm" class="auth-card auth-form auth-login-panel auth-login-panel-form" novalidate>
        <div class="auth-form-header">
          <h2>Welcome back</h2>
          <p>Enter your login credentials to continue.</p>
        </div>

        <label class="auth-field auth-field-floating">
          <input
            type="email"
            id="email"
            name="email"
            class="auth-input"
            placeholder="Email address"
            autocomplete="username"
            required
          >
          <span class="auth-label">Email Address</span>
        </label>

        <label class="auth-field auth-field-floating">
          <div class="auth-input-wrap">
            <input
              type="password"
              id="password"
              name="password"
              class="auth-input"
              placeholder="Enter your password"
              autocomplete="current-password"
              required
            >
            <button type="button" class="auth-icon-btn" data-password-toggle="password" aria-label="Show password">
              <span class="material-icons" aria-hidden="true">visibility_off</span>
            </button>
          </div>
          <span class="auth-label">Password</span>
        </label>

        <div id="formError" class="auth-message auth-message-error" aria-live="polite"></div>
        <div id="formSuccess" class="auth-message auth-message-success" aria-live="polite"></div>

        <button type="submit" id="loginBtn" class="auth-submit-btn">Log In</button>
        <div id="loginSpinner" class="auth-loading" aria-live="polite">Signing you in...</div>

        <div class="auth-links">
          <a href="/reset-password">Forgot Password?</a>
          <span>Don't have an account? <a href="/signup">Sign Up</a></span>
        </div>
      </form>
    </section>
  </main>

  <script src="/js/roleRedirects.js"></script>
  <script src="/js/authClient.js"></script>
  <script src="/js/auth/loginPage.js"></script>
</body>
</html>
