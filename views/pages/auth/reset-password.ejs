<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head', {
  title,
  description,
  canonicalUrl,
  stylesheets
}) %>
<body class="auth-page auth-page-reset">
  <%- include('../../partials/nav', {
    user: (typeof user !== 'undefined' ? user : undefined),
    role: (typeof role !== 'undefined' ? role : undefined),
    siteName: 'HelloUniversity'
  }) %>

  <main class="auth-shell">
    <section class="auth-hero-card auth-hero-card-wide">
      <div class="auth-copy">
        <p class="auth-eyebrow">Password Recovery</p>
        <h1>Recover access in three short steps.</h1>
        <p class="auth-subcopy">Enter your email, verify the reset code we send you, then create a new password that matches HelloUniversity password rules.</p>
        <ol class="auth-step-list" aria-label="Password reset steps">
          <li>Send reset code</li>
          <li>Verify reset code</li>
          <li>Create new password</li>
        </ol>
      </div>

      <section class="auth-card auth-form">
        <div class="auth-form-header">
          <h2>Reset Password</h2>
          <p>Move through the steps below to recover your account.</p>
        </div>

        <div class="auth-step-tabs" aria-label="Reset progress">
          <span class="auth-step-pill auth-step-pill-active" data-reset-step-pill="email">1. Email</span>
          <span class="auth-step-pill" data-reset-step-pill="code">2. Verify</span>
          <span class="auth-step-pill" data-reset-step-pill="password">3. New Password</span>
        </div>

        <div id="resetStatusMessage" class="auth-message auth-message-success" aria-live="polite"></div>
        <div id="resetErrorMessage" class="auth-message auth-message-error" aria-live="polite"></div>

        <form id="emailForm" class="auth-step-panel" data-reset-step="email" novalidate>
          <label class="auth-field">
            <span class="auth-label">Email Address</span>
            <input type="email" id="email" name="email" class="auth-input" placeholder="Enter your email" autocomplete="email" required>
          </label>
          <button type="submit" class="auth-submit-btn">Send Reset Code</button>
        </form>

        <form id="verifyResetCodeForm" class="auth-step-panel" data-reset-step="code" hidden novalidate>
          <label class="auth-field">
            <span class="auth-label">Reset Code</span>
            <input type="text" id="resetCode" name="resetCode" class="auth-input" placeholder="Enter the code from your email" required>
          </label>
          <div id="attemptsMessage" class="auth-inline-note"></div>
          <button type="submit" id="verifyResetCodeBtn" class="auth-submit-btn">Verify Code</button>
        </form>

        <form id="resetPasswordForm" class="auth-step-panel" data-reset-step="password" hidden novalidate>
          <label class="auth-field">
            <span class="auth-label">New Password</span>
            <div class="auth-input-wrap">
              <input type="password" id="newPassword" name="newPassword" class="auth-input" placeholder="Create a new password" autocomplete="new-password" required>
              <button type="button" class="auth-icon-btn" data-password-toggle="newPassword" aria-label="Show password">
                <span class="material-icons" aria-hidden="true">visibility_off</span>
              </button>
            </div>
          </label>

          <label class="auth-field">
            <span class="auth-label">Confirm Password</span>
            <div class="auth-input-wrap">
              <input type="password" id="confirmPassword" name="confirmPassword" class="auth-input" placeholder="Confirm your new password" autocomplete="new-password" required>
              <button type="button" class="auth-icon-btn" data-password-toggle="confirmPassword" aria-label="Show password">
                <span class="material-icons" aria-hidden="true">visibility_off</span>
              </button>
            </div>
          </label>

          <div class="auth-password-feedback">
            <small class="auth-password-hint">Min. 8 characters with uppercase, lowercase, number, and no special characters.</small>
            <div class="auth-password-strength" data-password-strength-for="newPassword" aria-label="Password strength" hidden>
              <div class="auth-strength-bar" aria-hidden="true">
                <div class="auth-strength-fill"></div>
              </div>
              <small class="auth-strength-text" aria-live="polite"></small>
            </div>
          </div>

          <button type="submit" class="auth-submit-btn">Reset Password</button>
        </form>

        <div class="auth-links">
          <a href="/login">Back to Login</a>
        </div>
      </section>
    </section>
  </main>

  <script src="/js/auth/passwordRules.js"></script>
  <script src="/js/auth/resetPasswordPage.js"></script>
</body>
</html>
