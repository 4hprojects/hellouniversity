<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head', {
  title,
  description,
  canonicalUrl,
  stylesheets
}) %>
<body class="auth-page auth-page-status">
  <%- include('../../partials/nav', { siteName: 'HelloUniversity' }) %>

  <main class="auth-shell">
    <section class="auth-hero-card">
      <div class="auth-copy">
        <p class="auth-eyebrow">Account Access</p>
        <h1><%= heading %></h1>
        <p class="auth-subcopy"><%= message %></p>
      </div>

      <section class="auth-card auth-form">
        <% if (showEmailForm) { %>
          <form method="get" action="/resend-confirmation">
            <label class="auth-field">
              <span class="auth-label">Email Address</span>
              <input type="email" name="email" class="auth-input" placeholder="Enter your email" value="<%= emailValue || '' %>" required>
            </label>
            <button type="submit" class="auth-submit-btn">Resend Confirmation Email</button>
          </form>
        <% } %>

        <div class="auth-links">
          <% if (primaryLinkHref && primaryLinkText) { %>
            <a href="<%= primaryLinkHref %>"><%= primaryLinkText %></a>
          <% } %>
          <% if (secondaryLinkHref && secondaryLinkText) { %>
            <a href="<%= secondaryLinkHref %>"><%= secondaryLinkText %></a>
          <% } %>
        </div>
      </section>
    </section>
  </main>
</body>
</html>
