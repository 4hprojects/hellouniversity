    <main class="main-content">
        <div class="container">
            <!-- Hero Section -->
            <section class="hero fade-in">
                <h1>About CRFV Event Management System</h1>
                <p>Your comprehensive solution for seamless event planning, registration, attendance tracking, and reporting. Learn how to make the most of our platform with this user guide.</p>
                <div class="mt-4">
                    <a href="#features" class="inline-block bg-emerald-600 hover:bg-emerald-700 text-white font-medium py-2 px-6 rounded-lg transition duration-300">Explore Features</a>
                </div>
            </section>
            
            <!-- Features Overview -->
            <section id="features" class="guide-section fade-in delay-1">
                <h2>System Features</h2>
                <div class="features-grid">
                    <div class="feature-card">
                        <h3><i class="material-icons">how_to_reg</i> Attendance Tracking</h3>
                        <ul>
                            <li><i class="material-icons">check_circle</i> Real-time check-in for participants</li>
                            <li><i class="material-icons">check_circle</i> QR code scanning capability</li>
                            <li><i class="material-icons">check_circle</i> Manual entry option</li>
                            <li><i class="material-icons">check_circle</i> Instant attendance confirmation</li>
                        </ul>
                    </div>
                    
                    <div class="feature-card">
                        <h3><i class="material-icons">person_add</i> Participant Registration</h3>
                        <ul>
                            <li><i class="material-icons">check_circle</i> Bulk import of participants</li>
                            <li><i class="material-icons">check_circle</i> Custom registration fields</li>
                            <li><i class="material-icons">check_circle</i> Automatic confirmation emails</li>
                            <li><i class="material-icons">check_circle</i> Badge printing integration</li>
                        </ul>
                    </div>
                    
                    <div class="feature-card">
                        <h3><i class="material-icons">event</i> Event Creation</h3>
                        <ul>
                            <li><i class="material-icons">check_circle</i> Custom event templates</li>
                            <li><i class="material-icons">check_circle</i> Schedule management</li>
                            <li><i class="material-icons">check_circle</i> Venue mapping</li>
                            <li><i class="material-icons">check_circle</i> Speaker management</li>
                        </ul>
                    </div>
                    
                    <div class="feature-card">
                        <h3><i class="material-icons">bar_chart</i> Reporting & Analytics</h3>
                        <ul>
                            <li><i class="material-icons">check_circle</i> Real-time attendance reports</li>
                            <li><i class="material-icons">check_circle</i> Participant demographics</li>
