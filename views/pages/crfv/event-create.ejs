<main class="two-panel-container">
  <section class="panel" id="createPanel">
    <div class="create-form-shell">
      <div class="header">
        <h1>Create Event</h1>
      </div>
      <form id="eventForm" class="attendance-card" autocomplete="off">
        <label>
          Event Name
          <input type="text" id="event_name" name="event_name" required>
        </label>
        <label class="event-inline-field">
          Event Start Date
          <input type="date" id="start_date" name="start_date" required>
        </label>
        <label class="event-inline-field">
          Event End Date
          <input type="date" id="end_date" name="end_date" required>
        </label>
        <label>
          Location
          <input type="text" id="location" name="location" required>
        </label>
        <label>
          Venue
          <input type="text" id="venue" name="venue" required>
        </label>
        <label class="event-inline-field">
          Event ID
          <input type="text" id="event_id" name="event_id" readonly class="readonly-field">
        </label>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Create Event</button>
        </div>
        <div id="eventStatus" class="event-status"></div>
      </form>
    </div>
  </section>

  <section class="panel" id="eventsPanel">
    <br>
    <div class="panel-content-centered">
      <h2 class="collapsible" data-target="latestEventsTable">
        <span class="collapse-icon">&#9660;</span> Upcoming Events
      </h2>
      <table class="events-table" id="latestEventsTable" style="display:table;">
        <thead>
          <tr>
            <th>Event ID</th>
            <th>Event Name</th>
            <th>Date</th>
            <th>Venue</th>
            <th>Location</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="latestEventsList"></tbody>
      </table>
    </div>
    <div class="panel-content-centered mt-8">
      <h2 class="collapsible" data-target="archivedEventsTable">
        <span class="collapse-icon">&#9660;</span> Completed Events (Archived)
      </h2>
      <table class="events-table" id="archivedEventsTable" style="display:table;">
        <thead>
          <tr>
            <th>Event ID</th>
            <th>Event Name</th>
            <th>Date</th>
            <th>Venue</th>
            <th>Location</th>
            <th>Status / Actions</th>
          </tr>
        </thead>
        <tbody id="archivedEventsList"></tbody>
      </table>
    </div>
    <div class="panel-content-centered mt-8">
      <h2 class="collapsible" data-target="allEventsTable">
        <span class="collapse-icon">&#9660;</span> All Events
      </h2>
      <table class="events-table" id="allEventsTable" style="display:table;">
        <thead>
          <tr>
            <th>Event ID</th>
            <th>Event Name</th>
            <th>Date</th>
            <th>Venue</th>
            <th>Location</th>
            <th>Status / Actions</th>
          </tr>
        </thead>
        <tbody id="allEventsList"></tbody>
      </table>
    </div>
  </section>
</main>

<div id="authModal" class="modal">
  <div class="modal-content" tabindex="0">
    <h2>Admin Login Required</h2>
    <p>You must be logged in as an admin to access this page.</p>
    <div class="modal-actions">
      <button id="goHomeBtn" class="btn btn-primary">Go to Home Page</button>
    </div>
  </div>
</div>

<%- include('../../partials/crfv/footer') %>
