<section class="crfv-migration-placeholder" style="max-width:900px;margin:2.5rem auto;padding:2rem;border:1px solid #E5E7EB;border-radius:12px;background:#FFFFFF;">
  <h1 style="margin:0 0 0.75rem;color:#1F2937;"><%= heading %></h1>
  <p style="margin:0 0 1rem;color:#6B7280;line-height:1.55;">
    <%= description %>
  </p>
  <p style="margin:0 0 1.25rem;color:#1F2937;">
    This route is now EJS-scaffolded for migration. The current production page remains available via legacy static HTML.
  </p>
  <a href="<%= legacyPath %>" style="display:inline-block;background:#10B981;color:#FFFFFF;padding:0.6rem 1rem;border-radius:8px;text-decoration:none;">
    Open Legacy Page
  </a>
</section>

