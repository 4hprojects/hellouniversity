<div class="app-container">
    <div class="header">
      <div class="header-content">
        <span class="brand-text">CRFV Event System</span>
        <div class="header-right">
          <span id="clock"></span>
          <!-- Add user/admin info here if needed -->
        </div>
      </div>
    </div>

    <div class="main-content">
      <div class="tabs-row">
        <h2>Payment Reports</h2>
      </div>

      <!-- Event Selector -->
      <div class="search-section">
        <div class="search-bar">
          <label for="eventSelect"><strong>Select Event:</strong></label>
          <select id="eventSelect">
            <option value="">-- Select an Event --</option>
            <!-- Populated by JS -->
          </select>
        </div>
      </div>

      <!-- Summary Section -->
      <div id="paymentSummary" class="search-section" style="display:none;">
        <!-- Populated by JS: total collected, receivable, per status, etc. -->
      </div>

      <!-- Column Picker -->
      <div class="search-section" id="columnPickerSection" style="display:none;">
        <label><strong>Columns:</strong></label>
        <div id="columnPicker" style="display:inline-block;"></div>
      </div>
      <button id="showColumnPickerBtn">Columns</button>
      <div id="columnPickerDropdown" style="display:none;position:absolute;z-index:10;">
        <!-- checkboxes here -->
      </div>

      <!-- Filters/Search -->
      <div class="search-section" id="filterSection" style="display:none;">
        <input type="text" id="paymentSearch" placeholder="Search payments...">
        <select id="statusFilter">
          <option value="">All Statuses</option>
          <!-- Populated by JS -->
        </select>
        <!-- Add more dropdowns if needed -->
        <div>
          <button class="export-btn" id="exportXLSXBtn"><i class="fas fa-file-excel"></i> Export XLSX</button>
          <button class="export-btn" id="exportPDFBtn"><i class="fas fa-file-pdf"></i> Export PDF</button>
        </div>
      </div>

      <!-- Payment Table -->
      <div class="table-container" id="paymentTableContainer" style="display:none;">
        <table id="paymentTable">
          <thead>
            <tr id="paymentTableHead">
              <!-- Populated by JS based on column picker -->
            </tr>
          </thead>
          <tbody id="paymentTableBody">
            <!-- Populated by JS -->
          </tbody>
        </table>
        <div class="pagination" id="paymentPagination"></div>
      </div>
    </div>
  </div>
  <!-- Payment Details Modal -->
  <div id="detailsModal" class="modal" style="display:none;">
    <div class="modal-content">
      <span class="close" id="closeModalBtn">&times;</span>
      <h3>Payment Details</h3>
      <form id="detailsForm">
        <div class="modal-fields">
          <!-- Example fields, repeat for all fields you want editable -->
          <label>Attendee No: <input name="attendee_no" readonly></label>
          <label>First Name: <input name="first_name"></label>
          <label>Last Name: <input name="last_name"></label>
          <label>Organization: <input name="organization"></label>
          <label>Payment Status: <input name="payment_status"></label>
          <label>Amount: <input name="amount" type="number" step="0.01"></label>
          <label>Form of Payment: <input name="form_of_payment"></label>
          <label>Date Full Payment: <input name="date_full_payment" type="date"></label>
          <label>Date Partial Payment: <input name="date_partial_payment" type="date"></label>
          <label>Account: <input name="account"></label>
          <label>OR Number: <input name="or_number"></label>
          <label>QuickBooks No: <input name="quickbooks_no"></label>
          <label>Shipping Tracking No: <input name="shipping_tracking_no"></label>
          <label>Notes: <textarea name="notes"></textarea></label>
          <label>Created At: <input name="created_at" readonly></label>
        </div>
        <div class="modal-actions">
          <button type="button" id="saveDetailsBtn">Save</button>
          <button type="button" id="cancelDetailsBtn">Cancel</button>
          <button type="button" id="deleteDetailsBtn" style="display:none;background:#e11d48;color:#fff;">Delete</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal CSS -->
  <style>
  .modal { position:fixed; top:0; left:0; width:100vw; height:100vh; background:rgba(0,0,0,0.4); display:flex; align-items:center; justify-content:center; z-index:1000; }
  .modal-content { background:#fff; padding:24px; border-radius:8px; min-width:320px; max-width:90vw; position:relative; }
  .close { position:absolute; top:8px; right:12px; font-size:24px; cursor:pointer; }
  .modal-fields label { display:block; margin-bottom:10px; }
  .modal-fields input, .modal-fields textarea { width:100%; }
  .modal-actions { margin-top:16px; display:flex; gap:12px; }
  </style>
