<div class="app-container payment-reports-page">
  <div class="main-content">
    <div class="tabs-row payment-reports-title-row">
      <div class="payment-reports-title-copy">
        <h2>Payment Reports</h2>
        <p class="payment-reports-subtitle">Review, edit, and export payment records for one CRFV event at a time.</p>
      </div>
      <a id="openPaymentAuditsLink" class="export-btn payment-reports-audits-link" href="/crfv/payment-audits">
        Open Payment Audits
      </a>
    </div>

    <section class="search-section payment-reports-event-section">
      <div class="search-bar payment-reports-event-bar">
        <label for="eventSelect"><strong>Select Event:</strong></label>
        <select id="eventSelect" aria-describedby="eventSelectHelp">
          <option value="">-- Select an Event --</option>
        </select>
      </div>
      <p id="eventSelectHelp" class="payment-reports-help">Choose a CRFV event to load editable payment records for that event only.</p>
    </section>

    <section id="selectedEventContext" class="payment-reports-event-context" hidden>
      <p class="payment-reports-event-context__eyebrow">Selected Event</p>
      <h3 id="selectedEventName" class="payment-reports-event-context__title">-</h3>
      <div class="payment-reports-event-context__meta">
        <span id="selectedEventIdLabel">Event ID: -</span>
        <span id="selectedEventDateLabel">Start Date: -</span>
      </div>
    </section>

    <section id="selectionEmptyState" class="payment-reports-empty-state">
      <h3>Select an event to review and edit payment records.</h3>
      <p>Load one CRFV event to view payment totals, search rows, export results, and safely update payment details.</p>
    </section>

    <section id="eventSummarySection" class="payment-reports-summary-section" hidden>
      <div id="paymentSummaryCards" class="payment-reports-summary-grid" aria-live="polite"></div>
      <div id="paymentStatusChips" class="payment-reports-status-chips" aria-live="polite"></div>
    </section>

    <section id="filterSection" class="search-section payment-reports-filter-section" hidden>
      <input type="text" id="paymentSearch" placeholder="Search attendee, OR number, notes, account, and more...">
      <select id="statusFilter">
        <option value="">All Statuses</option>
      </select>
      <div id="columnPickerSection" class="payment-reports-column-picker">
        <button
          id="showColumnPickerBtn"
          class="btn btn-secondary payment-reports-column-trigger"
          type="button"
          aria-haspopup="menu"
          aria-controls="columnPickerDropdown"
        >
          <span class="payment-reports-column-trigger__label">Columns</span>
          <span id="columnPickerCount" class="payment-reports-column-trigger__count" aria-live="polite">7 visible</span>
          <span class="payment-reports-column-trigger__icon" aria-hidden="true">v</span>
        </button>
        <div id="columnPickerDropdown" style="display:none;"></div>
      </div>
      <div class="payment-reports-actions">
        <button class="export-btn" id="exportXLSXBtn" type="button"><i class="fas fa-file-excel"></i> Export XLSX</button>
        <button class="export-btn" id="exportPDFBtn" type="button"><i class="fas fa-file-pdf"></i> Export PDF</button>
      </div>
    </section>

    <div id="resultsMetaRow" class="payment-reports-meta-row" hidden>
      <div id="paymentResultsSummary" class="payment-reports-results-summary" aria-live="polite"></div>
      <label class="payment-reports-rows-label" for="rowsPerPageSelect">
        Rows per page
        <select id="rowsPerPageSelect">
          <option value="25">25</option>
          <option value="50">50</option>
          <option value="100">100</option>
          <option value="all">All</option>
        </select>
      </label>
    </div>

    <section id="tableSection" class="payment-reports-table-section" hidden>
      <div id="recordsEmptyState" class="payment-reports-empty-state payment-reports-empty-state--compact" hidden></div>

      <div class="table-container payment-reports-table-shell" id="paymentTableContainer" hidden>
        <table id="paymentTable">
          <thead>
            <tr id="paymentTableHead"></tr>
          </thead>
          <tbody id="paymentTableBody"></tbody>
        </table>
      </div>

      <div class="pagination payment-reports-pagination" id="paymentPagination" hidden></div>
    </section>
  </div>
</div>

<div id="detailsModal" class="payment-report-modal" hidden>
  <div class="payment-report-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="detailsModalTitle">
    <button type="button" id="closeModalBtn" class="payment-report-modal__close" aria-label="Close payment details">&times;</button>

    <div class="payment-report-modal__header">
      <div>
        <h3 id="detailsModalTitle">Payment Details</h3>
        <p class="payment-report-modal__subtitle">Review record identity and update the payment fields for this attendee.</p>
      </div>
    </div>

    <form id="detailsForm" class="payment-report-modal__form">
      <section class="payment-report-modal__section">
        <h4>Record Identity</h4>
        <div class="payment-report-modal__grid payment-report-modal__grid--identity">
          <label>
            <span>Payment ID</span>
            <input name="payment_id_display" readonly>
          </label>
          <label>
            <span>Attendee No</span>
            <input name="attendee_no" readonly>
          </label>
          <label>
            <span>Attendee Name</span>
            <input name="attendee_name_display" readonly>
          </label>
          <label>
            <span>Organization</span>
            <input name="organization" readonly>
          </label>
          <label>
            <span>Created At</span>
            <input name="created_at_display" readonly>
          </label>
        </div>
      </section>

      <section class="payment-report-modal__section">
        <h4>Payment Details</h4>
        <div class="payment-report-modal__grid payment-report-modal__grid--details">
          <label>
            <span>Payment Status</span>
            <select name="payment_status" id="paymentStatusInput"></select>
          </label>
          <label>
            <span>Amount</span>
            <input name="amount" type="number" step="0.01">
          </label>
          <label>
            <span>Form of Payment</span>
            <input name="form_of_payment">
          </label>
          <label>
            <span>Date Full Payment</span>
            <input name="date_full_payment" type="date">
          </label>
          <label>
            <span>Date Partial Payment</span>
            <input name="date_partial_payment" type="date">
          </label>
          <label>
            <span>Account</span>
            <input name="account">
          </label>
          <label>
            <span>OR Number</span>
            <input name="or_number">
          </label>
          <label>
            <span>QuickBooks Number</span>
            <input name="quickbooks_no">
          </label>
          <label>
            <span>Shipping Tracking Number</span>
            <input name="shipping_tracking_no">
          </label>
          <label class="payment-report-modal__notes-field">
            <span>Notes</span>
            <textarea name="notes" rows="4"></textarea>
          </label>
        </div>
      </section>

      <div class="payment-report-modal__footer">
        <div class="payment-report-modal__footer-left">
          <button type="button" id="deleteDetailsBtn" class="payment-report-modal__delete-btn">Delete Record</button>
        </div>
        <div class="payment-report-modal__footer-right">
          <button type="button" id="cancelDetailsBtn" class="payment-report-modal__cancel-btn">Cancel</button>
          <button type="button" id="saveDetailsBtn" class="payment-report-modal__save-btn">Save Changes</button>
        </div>
      </div>
    </form>
  </div>
</div>
