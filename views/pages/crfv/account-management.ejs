<div class="am-shell">
  <section class="am-page-intro">
    <p class="am-page-kicker">CRFV Admin</p>
    <h1 class="am-page-title">CRFV Account Management</h1>
    <p class="am-page-copy">Create staff accounts and support CRFV login access.</p>
  </section>

  <section class="am-grid">
    <section class="am-panel">
      <div class="am-panel-header">
        <div>
          <p class="am-section-kicker">Find</p>
          <h2 class="am-panel-title">Accounts</h2>
        </div>
        <button id="openCreateAccountBtn" class="am-btn am-btn-primary" type="button">
          <span class="material-icons" aria-hidden="true">person_add</span>
          New Account
        </button>
      </div>

      <form id="accountSearchForm" class="am-search">
        <label class="am-field am-search-field">
          <span>Search</span>
          <input id="accountSearchInput" type="search" placeholder="Name, email, role, or user ID">
        </label>
        <button class="am-btn am-btn-muted" type="submit">
          <span class="material-icons" aria-hidden="true">person_search</span>
          Search
        </button>
      </form>

      <div class="am-table-shell">
        <table class="am-table">
          <thead>
            <tr>
              <th><button class="am-sort-header" type="button" data-sort="name">Name <span class="am-sort-icon" aria-hidden="true"></span></button></th>
              <th><button class="am-sort-header" type="button" data-sort="studentIDNumber">User ID <span class="am-sort-icon" aria-hidden="true"></span></button></th>
              <th><button class="am-sort-header" type="button" data-sort="emaildb">Email <span class="am-sort-icon" aria-hidden="true"></span></button></th>
              <th><button class="am-sort-header" type="button" data-sort="role">Role <span class="am-sort-icon" aria-hidden="true"></span></button></th>
              <th><button class="am-sort-header" type="button" data-sort="status">Status <span class="am-sort-icon" aria-hidden="true"></span></button></th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="accountsTableBody">
            <tr><td colspan="6" class="am-empty">Loading accounts...</td></tr>
          </tbody>
        </table>
      </div>

      <div class="am-pagination" id="accountsPagination" aria-label="Account pages"></div>
      <p id="accountsStatus" class="am-status" aria-live="polite"></p>
    </section>

    <section class="am-panel">
      <div class="am-panel-header">
        <div>
          <p class="am-section-kicker">Trace</p>
          <h2 class="am-panel-title">Account Audit Trail</h2>
        </div>
        <button id="refreshAuditTrailBtn" class="am-btn am-btn-muted" type="button">
          <span class="material-icons" aria-hidden="true">refresh</span>
          Refresh
        </button>
      </div>

      <div class="am-table-shell am-audit-table-shell">
        <table class="am-table am-audit-table">
          <thead>
            <tr>
              <th>When</th>
              <th>Actor</th>
              <th>Target</th>
              <th>Action</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody id="accountAuditTrailBody">
            <tr><td colspan="5" class="am-empty">Loading account changes...</td></tr>
          </tbody>
        </table>
      </div>
      <p id="accountAuditTrailStatus" class="am-status" aria-live="polite"></p>
    </section>
  </section>
</div>

<div id="createAccountModal" class="am-floating-modal" hidden>
  <div class="am-floating-overlay"></div>
  <div class="am-floating-panel">
    <div class="am-floating-header">
      <div>
        <p class="am-section-kicker">Create</p>
        <h2 class="am-floating-title">New Account</h2>
      </div>
      <button id="closeCreateAccountBtn" class="am-icon-btn" type="button" aria-label="Close create account modal">
        <span class="material-icons" aria-hidden="true">close</span>
      </button>
    </div>

    <form id="createAccountForm" class="am-form" autocomplete="off">
      <div class="am-form-grid">
        <div class="am-field am-field-floating">
          <div class="input-group">
            <label for="createFirstName">First Name</label>
            <input id="createFirstName" name="firstName" type="text" maxlength="60" required>
          </div>
        </div>
        <div class="am-field am-field-floating">
          <div class="input-group">
            <label for="createLastName">Last Name</label>
            <input id="createLastName" name="lastName" type="text" maxlength="60" required>
          </div>
        </div>
        <div class="am-field am-field-floating">
          <div class="input-group">
            <label for="createEmail">Email</label>
            <input id="createEmail" name="email" type="email" maxlength="120" required>
          </div>
        </div>
        <div class="am-field am-field-floating">
          <div class="input-group">
            <label for="createRole">Role</label>
            <select id="createRole" name="role" required>
              <option value="staff">staff</option>
              <option value="manager">manager</option>
            </select>
          </div>
        </div>
      </div>
      <p class="am-hint">
        A User ID and temporary password will be generated automatically and emailed to the new account.
      </p>

      <div class="am-actions">
        <button class="am-btn am-btn-primary" type="submit">
          <span class="material-icons" aria-hidden="true">person_add</span>
          Create Account
        </button>
      </div>
      <p id="createAccountStatus" class="am-status" aria-live="polite"></p>
    </form>
  </div>
</div>

<div id="accountModal" class="am-modal" role="dialog" aria-modal="true" aria-labelledby="accountModalTitle" hidden>
  <div class="am-modal-card">
    <div class="am-modal-header">
      <div>
        <p class="am-section-kicker">Manage</p>
        <h2 id="accountModalTitle" class="am-modal-title">Selected Account</h2>
      </div>
      <button id="closeAccountModalBtn" class="am-icon-btn" type="button" aria-label="Close account modal">
        <span class="material-icons" aria-hidden="true">close</span>
      </button>
    </div>

    <div id="selectedAccountSummary" class="am-summary">No account selected.</div>

    <section class="am-modal-section">
      <div class="am-modal-section-header">
        <h3>Account Activity</h3>
        <button id="refreshSelectedAuditBtn" class="am-btn am-btn-muted" type="button" data-tooltip="Reload the latest audit entries for this selected account.">
          <span class="material-icons" aria-hidden="true">refresh</span>
          Refresh
        </button>
      </div>
      <div id="selectedAccountAuditList" class="am-audit-list" aria-live="polite">
        Select an account to load activity.
      </div>
    </section>

    <form id="featureAccessForm" class="am-modal-section">
      <h3>CRFV Feature Access</h3>
      <div id="featureAccessList" class="am-feature-list" aria-label="CRFV feature access"></div>
      <div class="am-actions">
        <button id="saveFeatureAccessBtn" class="am-btn am-btn-primary" type="submit" data-tooltip="Save which CRFV pages and tools this account can open.">
          <span class="material-icons" aria-hidden="true">visibility</span>
          Save Feature Access
        </button>
      </div>
    </form>

    <form id="roleChangeForm" class="am-modal-section">
      <h3>Role</h3>
      <div class="am-inline-form">
        <div class="am-field am-field-floating">
          <div class="input-group" data-tooltip="Choose whether this account is staff or manager.">
            <label for="selectedRole">New Role</label>
            <select id="selectedRole" required>
              <option value="staff">staff</option>
              <option value="manager">manager</option>
            </select>
          </div>
        </div>
        <div class="am-field am-field-floating">
          <div class="input-group" data-tooltip="Enter your admin password to authorize this role change.">
            <label for="roleAdminPassword">Admin Password</label>
            <input id="roleAdminPassword" type="password" autocomplete="current-password" required>
            <button class="am-password-toggle" type="button" data-password-toggle="roleAdminPassword" data-tooltip="Show or hide the admin password." aria-label="Show admin password" aria-pressed="false">
              <span class="material-icons" aria-hidden="true">visibility</span>
            </button>
          </div>
        </div>
        <button class="am-btn am-btn-primary" type="submit" data-tooltip="Apply the selected role after admin password verification.">Update Role</button>
      </div>
    </form>

    <form id="temporaryPasswordForm" class="am-modal-section">
      <h3>Temporary Password</h3>
      <div class="am-inline-form">
        <div class="am-field am-field-floating">
          <div class="input-group" data-tooltip="Enter a temporary password that meets the account password rules.">
            <label for="temporaryPassword">New Password</label>
            <input id="temporaryPassword" type="password" autocomplete="new-password" required>
            <button class="am-password-toggle" type="button" data-password-toggle="temporaryPassword" data-tooltip="Show or hide the new password." aria-label="Show new password" aria-pressed="false">
              <span class="material-icons" aria-hidden="true">visibility</span>
            </button>
          </div>
        </div>
        <div class="am-field am-field-floating">
          <div class="input-group" data-tooltip="Re-enter the temporary password to confirm it before saving.">
            <label for="temporaryPasswordConfirm">Confirm Password</label>
            <input id="temporaryPasswordConfirm" type="password" autocomplete="new-password" required>
            <button class="am-password-toggle" type="button" data-password-toggle="temporaryPasswordConfirm" data-tooltip="Show or hide the confirmation password." aria-label="Show confirm password" aria-pressed="false">
              <span class="material-icons" aria-hidden="true">visibility</span>
            </button>
          </div>
        </div>
        <button class="am-btn am-btn-danger" type="submit" data-tooltip="Set a new temporary password for the selected account.">Set Password</button>
      </div>
    </form>

    <div class="am-modal-section">
      <h3>Recovery</h3>
      <div class="am-button-row">
        <button id="sendResetCodeBtn" class="am-btn am-btn-muted" type="button" data-tooltip="Email a password reset code to the selected account.">
          <span class="material-icons" aria-hidden="true">mail</span>
          Send Reset Code
        </button>
        <button id="resetRecoveryFieldsBtn" class="am-btn am-btn-muted" type="button" data-tooltip="Clear lockout and recovery reset fields for the selected account.">
          <span class="material-icons" aria-hidden="true">lock_reset</span>
          Unlock / Reset Fields
        </button>
      </div>
    </div>

    <form id="accountActionForm" class="am-modal-section">
      <h3>Account Status</h3>
      <div class="am-inline-form">
        <div class="am-field am-field-floating">
          <div class="input-group" data-tooltip="Choose whether to suspend access or permanently delete this account.">
            <label for="accountActionType">Action</label>
            <select id="accountActionType" required>
              <option value="suspend">Suspend account</option>
              <option value="delete">Delete account</option>
            </select>
          </div>
        </div>
        <div class="am-field am-field-floating">
          <div class="input-group" data-tooltip="Select the reason that best explains this account action.">
            <label for="accountActionReason">Reason</label>
            <select id="accountActionReason" required>
              <option value="Policy violation">Policy violation</option>
              <option value="Security concern">Security concern</option>
              <option value="Duplicate account">Duplicate account</option>
              <option value="No longer affiliated">No longer affiliated</option>
              <option value="Requested by account owner">Requested by account owner</option>
              <option value="Administrative cleanup">Administrative cleanup</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>
        <div id="accountActionOtherField" class="am-field am-field-floating" hidden>
          <div class="input-group" data-tooltip="Enter the reason when the listed options do not fit.">
            <label for="accountActionOtherReason">Other Reason</label>
            <input id="accountActionOtherReason" type="text" maxlength="180">
          </div>
        </div>
        <div class="am-field am-field-floating">
          <div class="input-group" data-tooltip="Enter your admin password to confirm this account action.">
            <label for="accountActionAdminPassword">Admin Password</label>
            <input id="accountActionAdminPassword" type="password" autocomplete="current-password" required>
            <button class="am-password-toggle" type="button" data-password-toggle="accountActionAdminPassword" data-tooltip="Show or hide the admin password." aria-label="Show account action admin password" aria-pressed="false">
              <span class="material-icons" aria-hidden="true">visibility</span>
            </button>
          </div>
        </div>
        <button id="runAccountActionBtn" class="am-btn am-btn-danger" type="submit" data-tooltip="Suspend or delete the selected account after password confirmation.">
          Apply Account Action
        </button>
      </div>
    </form>

    <p id="accountModalStatus" class="am-status" aria-live="polite"></p>
  </div>
</div>

<div id="confirmationModal" class="am-modal" role="dialog" aria-modal="true" aria-labelledby="confirmationTitle" hidden>
  <div class="am-modal-card am-confirmation-card">
    <div class="am-modal-header">
      <h2 id="confirmationTitle" class="am-modal-title">Confirm Action</h2>
    </div>
    <div id="confirmationBody" class="am-confirmation-body"></div>
    <div class="am-modal-actions">
      <button id="cancelConfirmBtn" class="am-btn am-btn-muted" type="button" data-tooltip="Close this confirmation without making changes.">Cancel</button>
      <button id="confirmActionBtn" class="am-btn am-btn-danger" type="button" data-tooltip="Confirm and run the selected account action.">Confirm</button>
    </div>
  </div>
</div>
