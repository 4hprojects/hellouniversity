<div class="app-container audittrail-page">
  <details class="brand audittrail-intro">
    <summary class="audittrail-intro__summary">
      Audit Trail Logs
    </summary>
    <div class="audittrail-intro__body">
      <p>
        Welcome to the Audit Trail Logs for the CRFV Event Management System.
        Monitor, search, filter, sort, and export system activity for security
        review and compliance.
      </p>
      <ul class="audittrail-intro__list">
        <li>Search by user, role, action, or details.</li>
        <li>Filter by date range and choose a page size.</li>
        <li>Sort columns across the full filtered audit log.</li>
        <li>Export the visible page or all rows matching the active filters.</li>
      </ul>
    </div>
  </details>

  <section class="main-menu audittrail-panel" aria-labelledby="auditTrailHeading">
    <div class="audittrail-panel__header">
      <div>
        <p class="audittrail-eyebrow">System log review</p>
        <h2 id="auditTrailHeading">Audit Trail</h2>
      </div>
      <p id="auditTrailStatus" class="audittrail-status" aria-live="polite">
        Loading latest logs...
      </p>
    </div>

    <form id="auditFilters" class="search-bar-controls audit-filter-panel" role="search" aria-label="Audit log filters">
      <div class="audit-control audit-control--search">
        <label for="searchLogs">Search logs</label>
        <input type="search" id="searchLogs" placeholder="User, role, action, or details" autocomplete="off">
      </div>

      <div class="audit-control">
        <label for="logsLimit">Rows per page</label>
        <select id="logsLimit">
          <option value="50">50</option>
          <option value="100">100</option>
          <option value="250">250</option>
          <option value="500">500</option>
          <option value="1000">1000</option>
        </select>
      </div>

      <div class="audit-control">
        <label for="dateFrom">From date</label>
        <input type="date" id="dateFrom">
      </div>

      <div class="audit-control">
        <label for="dateTo">To date</label>
        <input type="date" id="dateTo">
      </div>

      <div class="audit-filter-actions">
        <button id="clearFiltersBtn" class="btn btn-muted" type="button">
          Clear filters
        </button>
      </div>
    </form>

    <div class="results-export-row">
      <div id="logsResultsSummary" class="logs-results-summary" aria-live="polite"></div>
      <div class="inline-pagination" id="inlinePagination" aria-label="Top audit log pagination"></div>
      <div class="export-controls">
        <label class="sr-only" for="exportType">Export scope</label>
        <select id="exportType">
          <option value="visible">Visible Page</option>
          <option value="allFiltered">All Filtered</option>
        </select>
        <button id="exportBtn" class="btn" type="button">
          <i class="fas fa-file-export" aria-hidden="true"></i>
          <span id="exportBtnLabel">Export</span>
        </button>
      </div>
    </div>

    <div id="exportProgress" class="audit-progress" aria-live="polite" hidden></div>
    <div id="auditError" class="audit-state audit-state--error" role="alert" hidden></div>
    <div id="auditEmptyState" class="audit-state audit-state--empty" hidden>
      No audit logs match the current filters.
    </div>

    <div class="table-container audittrail-table-shell">
      <table id="logs-table" aria-describedby="logsResultsSummary">
        <thead>
          <tr>
            <th class="sortable" data-field="user_name" scope="col" aria-sort="none">
              <button class="sort-button" type="button" data-field="user_name">
                <span>User</span><span class="sort-icon" aria-hidden="true"></span>
              </button>
            </th>
            <th class="sortable" data-field="user_role" scope="col" aria-sort="none">
              <button class="sort-button" type="button" data-field="user_role">
                <span>Role</span><span class="sort-icon" aria-hidden="true"></span>
              </button>
            </th>
            <th class="sortable" data-field="action" scope="col" aria-sort="none">
              <button class="sort-button" type="button" data-field="action">
                <span>Action</span><span class="sort-icon" aria-hidden="true"></span>
              </button>
            </th>
            <th class="sortable" data-field="action_time" scope="col" aria-sort="descending">
              <button class="sort-button" type="button" data-field="action_time">
                <span>Date/Time</span><span class="sort-icon" aria-hidden="true"></span>
              </button>
            </th>
            <th class="sortable" data-field="ip_address" scope="col" aria-sort="none">
              <button class="sort-button" type="button" data-field="ip_address">
                <span>IP</span><span class="sort-icon" aria-hidden="true"></span>
              </button>
            </th>
            <th class="sortable" data-field="details" scope="col" aria-sort="none">
              <button class="sort-button" type="button" data-field="details">
                <span>Details</span><span class="sort-icon" aria-hidden="true"></span>
              </button>
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="6" class="audit-table-message">Loading logs...</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div id="loadingSpinner" class="loading-spinner" hidden>
      <i class="fas fa-spinner fa-spin fa-2x" aria-hidden="true"></i>
      <span class="sr-only">Loading audit logs</span>
    </div>

    <div id="logsPagination" class="pagination audit-pagination" aria-label="Audit log pagination"></div>
  </section>

  <div class="audittrail-ad-slot">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-format="fluid"
         data-ad-layout-key="-gw-3+1f-3d+2z"
         data-ad-client="ca-pub-4537208011192461"
         data-ad-slot="1905924631"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
</div>
