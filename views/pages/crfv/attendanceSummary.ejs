<div class="app-container attendance-summary-page">
  <h2 class="attendance-summary-title"><i class="fas fa-calendar-check"></i> Attendance Summary</h2>

  <div class="controls-container attendance-summary-controls">
    <div class="control-group">
      <label for="eventDropdown"><i class="fas fa-calendar-alt"></i> SELECT EVENT</label>
      <select id="eventDropdown">
        <option value="">Loading events...</option>
      </select>
    </div>
    <div class="control-group">
      <label for="attendanceDate"><i class="fas fa-calendar-day"></i> SELECT DATE</label>
      <input type="date" id="attendanceDate">
    </div>
    <div class="control-group">
      <label for="attendanceSearch"><i class="fas fa-search"></i> SEARCH ATTENDEES</label>
      <input type="search" id="attendanceSearch" placeholder="Search attendee number, name, or email..." autocomplete="off">
    </div>
  </div>

  <div class="attendance-summary-state">
    <div id="attendanceSummaryStatus" class="attendance-summary-status" aria-live="polite">Loading events...</div>
    <div id="attendanceExportProgress" class="attendance-summary-progress" aria-live="polite" hidden></div>
  </div>

  <div class="summary-counters attendance-summary-counters">
    <div class="counter total">
      <h3>TOTAL ATTENDEES</h3>
      <div class="count" id="countTotalAttendees">0</div>
    </div>
    <div class="counter am-in">
      <h3>AM IN</h3>
      <div class="count" id="countAMIn">0</div>
    </div>
    <div class="counter am-out">
      <h3>AM OUT</h3>
      <div class="count" id="countAMOut">0</div>
    </div>
    <div class="counter pm-in">
      <h3>PM IN</h3>
      <div class="count" id="countPMIn">0</div>
    </div>
    <div class="counter pm-out">
      <h3>PM OUT</h3>
      <div class="count" id="countPMOut">0</div>
    </div>
    <div class="counter am-in">
      <h3>AM IN ON TIME</h3>
      <div class="count" id="countAMInOnTime">0</div>
    </div>
    <div class="counter am-out">
      <h3>AM IN LATE</h3>
      <div class="count" id="countAMInLate">0</div>
    </div>
    <div class="counter pm-in">
      <h3>PM IN ON TIME</h3>
      <div class="count" id="countPMInOnTime">0</div>
    </div>
    <div class="counter pm-out">
      <h3>PM IN LATE</h3>
      <div class="count" id="countPMInLate">0</div>
    </div>
  </div>

  <div class="export-section attendance-summary-actions">
    <div class="export-options">
      <label><input type="radio" name="exportOption" value="all" checked> Export All</label>
      <label><input type="radio" name="exportOption" value="selected"> Export Selected</label>
    </div>
    <button id="exportAttendanceSummaryBtn">
      <i class="fas fa-file-excel"></i> Export to Excel
    </button>
    <div class="pagination attendance-summary-pagination">
      <div class="pagination-size">
        <label for="paginationSelect">Rows per page: </label>
        <select id="paginationSelect">
          <option value="10">10</option>
          <option value="25">25</option>
          <option value="50" selected>50</option>
          <option value="100">100</option>
          <option value="250">250</option>
          <option value="500">500</option>
          <option value="1000">1000</option>
        </select>
      </div>
      <div class="pagination-info" id="paginationInfo">Page 1 of 1</div>
      <div class="pagination-controls">
        <button id="prevPageBtn"><i class="fas fa-chevron-left"></i> Prev</button>
        <button id="nextPageBtn">Next <i class="fas fa-chevron-right"></i></button>
      </div>
    </div>
  </div>

  <div class="attendance-summary-table-meta" aria-live="polite">
    <span class="attendance-summary-table-meta-label">Selected Event</span>
    <span id="selectedEventLabel" class="attendance-summary-table-meta-value">No event selected</span>
  </div>

  <div class="table-container attendance-summary-table-shell">
    <table id="attendanceSummaryTable">
      <thead>
        <tr>
          <th class="checkbox-cell"><input type="checkbox" id="selectAllRows" aria-label="Select visible attendance rows"></th>
          <th data-column="attendee_no" class="sortable" aria-sort="none"><button type="button" class="sort-button" data-column="attendee_no">Attendee No <span class="sort-icon" aria-hidden="true"></span></button></th>
          <th data-column="first_name" class="sortable" aria-sort="none"><button type="button" class="sort-button" data-column="first_name">First Name <span class="sort-icon" aria-hidden="true"></span></button></th>
          <th data-column="last_name" class="sortable" aria-sort="ascending"><button type="button" class="sort-button" data-column="last_name">Last Name <span class="sort-icon" aria-hidden="true"></span></button></th>
          <th data-column="am_in">AM IN</th>
          <th data-column="am_in_status">AM IN Status</th>
          <th data-column="am_in_late_minutes">AM IN Late Min</th>
          <th data-column="am_out">AM OUT</th>
          <th data-column="pm_in">PM IN</th>
          <th data-column="pm_in_status">PM IN Status</th>
          <th data-column="pm_in_late_minutes">PM IN Late Min</th>
          <th data-column="pm_out">PM OUT</th>
          <th data-column="date">Date</th>
          <th data-column="attendance_status">Attendance Status</th>
        </tr>
      </thead>
      <tbody id="attendanceTableBody">
        <tr>
          <td colspan="14">Loading attendance summary...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div id="noRecordsLabel" class="no-records" hidden>
    <i class="fas fa-exclamation-circle"></i> No attendance records found for the selected date.
  </div>
</div>
