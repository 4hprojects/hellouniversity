<!-- Login Modal -->
    <div id="loginModal" class="login-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Admin Login Required</h2>
                <p>Please authenticate to access this page</p>
            </div>
            <form id="loginForm" class="login-form">
                <div class="form-row">
                    <label for="studentIDNumber" class="required">Student ID Number</label>
                    <div class="input-group">
                        <i class="material-icons input-icon">badge</i>
                        <input type="text" id="studentIDNumber" name="studentIDNumber" required placeholder="Enter your student ID">
                    </div>
                </div>
                
                <div class="form-row">
                    <label for="password" class="required">Password</label>
                    <div class="input-group">
                        <i class="material-icons input-icon">lock</i>
                        <input type="password" id="password" name="password" required placeholder="Enter your password">
                    </div>
                </div>
                
                <button type="submit" class="login-btn">Sign In</button>
                
                <div id="loginMessage" style="margin-top: 1rem; text-align: center;"></div>
            </form>
        </div>
    </div>

    <!-- Main Content -->
    <header class="header">
        <div class="header-container" style="display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto;">
            <div class="logo" style="display: flex; align-items: center; gap: 0.8rem; font-size: 1.5rem; font-weight: 700;">
                <i class="fas fa-calendar-check" aria-hidden="true"></i>
                <span>CRFV Event System</span>
            </div>
            <nav aria-label="Main navigation">
                <ul style="display: flex; gap: 1.5rem; list-style: none;">
                    <li><a href="/crfv/index"><i class="fas fa-home"></i> Home</a></li>
                    <li><a href="/crfv/attendance"><i class="fas fa-user-check"></i> Attendance</a></li>
                    <li><a href="/crfv/admin-register"><i class="fas fa-user-plus"></i> Register</a></li>
                    <li><a href="/crfv/event-create"><i class="fas fa-calendar-plus"></i> Create Event</a></li>
                    <li><a href="/crfv/reports"><i class="fas fa-file-alt"></i> Reports</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="admin-container">
        <!-- Panel 1: Single Registration -->
        <div class="panel register-container">
            <div class="panel-header">
                <h2>Single User Registration</h2>
            </div>
            <form id="registerForm" class="form-horizontal" autocomplete="off">
                <!-- Event Selection -->
                <div class="form-row">
                    <label for="event_id">Event <span class="required">*</span></label>
                    <select id="event_id" name="event_id" required></select>
                </div>
                <!-- Personal Information -->
                <div class="form-row">
                    <label for="first_name">First Name <span class="required">*</span></label>
                    <div class="form-input">
                        <input type="text" id="first_name" name="first_name" required>
                    </div>
                </div>
                <div class="form-row">
                    <label for="middle_name">Middle Name</label>
                    <input type="text" id="middle_name" name="middle_name">
                </div>
                <div class="form-row">
                    <label for="last_name">Last Name <span class="required">*</span></label>
                    <input type="text" id="last_name" name="last_name" required>
                </div>
                <div class="form-row">
                    <label for="gender">Gender</label>
                    <select id="gender" name="gender">
                        <option value="">-- Select --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Prefer not to say">Prefer not to say</option>
                    </select>
                </div>
                <div class="form-row">
                    <label for="designation">Designation</label>
                    <input type="text" id="designation" name="designation">
                </div>
                <div class="form-row">
                    <label for="organization">Organization <span class="required">*</span></label>
                    <input type="text" id="organization" name="organization" required>
                </div>
                <div class="form-row">
                    <label for="email">Email <span class="required">*</span></label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-row">
                    <label for="phone_no">Contact No.</label>
                    <input type="text" id="phone_no" name="phone_no">
                </div>
                <!-- Accommodation -->
                <div class="form-row">
                    <label for="accommodation">Accommodation</label>
                    <select id="accommodation" name="accommodation">
                        <option value="">Select accommodation type</option>
                        <option value="Online / Virtual">Online / Virtual</option>
                        <option value="Live-Out">Live-Out</option>
                        <option value="FB Quad">FB Quad (4 person)</option>
                        <option value="FB Triple">FB Triple (3 person)</option>
                        <option value="FB Double">FB Double (2 person)</option>
                        <option value="FB Single">FB Single</option>
                        <option value="Others">Others (please specify)</option>
                    </select>
                </div>
                <div class="form-row" id="accommodationOtherRow" style="display:none;">
                    <label for="accommodationOther">If Other, specify <span class="required">*</span></label>
                    <input type="text" id="accommodationOther" name="accommodationOther">
                </div>
                <!-- Certificate and RFID -->
                <div class="form-row">
                    <label for="certificateName">Certificate Name</label>
                    <input type="text" id="certificateName" name="certificateName" placeholder="(Optional)">
                </div>
                <div class="form-row">
                    <label for="rfid">RFID</label>
                    <input type="text" id="rfid" name="rfid" required placeholder="Enter RFID">
                </div>
                <div class="form-row form-row-full">
                    <button type="submit">Register</button>
                </div>
                <div class="form-row form-row-full">
                    <div id="regStatus"></div>
                </div>
            </form>
        </div>
         
        <!-- Panel 2: Bulk Upload -->
        <div class="panel bulk-panel">
          <div class="bulk-upload">
            <div class="bulk-icon">
              <i class="material-icons">cloud_upload</i>
            </div>
            <h3>Bulk Registration from Google Sheets</h3>
            <p class="bulk-desc">Import pre-registered attendees for a selected event. Only rows with blank status and matching event will be processed.</p>
            <div class="form-row">
              <label for="bulkEventSelect">Select Event for Bulk Registration</label>
              <select id="bulkEventSelect" required>
                <option value="">Loading events...</option>
              </select>
            </div>
            <div class="form-row">
              <label for="bulkFileInput">Upload XLSX File</label>
              <input type="file" id="bulkFileInput" accept=".xlsx,.xls" />
            </div>
            <div class="form-row">
              <button id="uploadBulkBtn" type="button" disabled>Upload & Register</button>
            </div>
            <div class="form-row">
              <div id="bulkUploadStatus"></div>
            </div>
          </div>
        </div>

