<section id="homeCapabilities" class="hu-section hu-bg-light">
  <div class="container">
    <div class="hu-section-header">
      <span class="hu-eyebrow">Capabilities</span>
      <h2>Everything you need, nothing you don't</h2>
      <p>HelloUniversity is a digital academic platform that brings classes, assessments, communication, and learning management into one connected product surface.</p>
    </div>

    <div class="hu-features-grid">
      <% capabilityCards.forEach(function(card) { %>
        <article class="hu-feature">
          <span class="material-icons hu-feature-icon" aria-hidden="true"><%= card.icon %></span>
          <h3><%= card.title %></h3>
          <p><%= card.description %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>
