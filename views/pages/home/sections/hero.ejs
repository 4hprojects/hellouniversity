<section id="homeOverview" class="hu-hero">
  <div class="container hu-hero-grid">
    <div class="hu-hero-content">
      <span class="hu-eyebrow"><%= brandName || 'HelloUniversity' %></span>
      <h1>All-in-one platform for <span class="hu-highlight">education</span></h1>
      <p class="hu-hero-subhead">
        Unify lessons, quizzes, attendance, and campus operations in one intuitive workspace. Built for students, teachers, and administrators with a mobile-first public entry point.
      </p>
      <div class="hu-hero-actions">
        <a href="<%= heroPrimaryAction.href %>" class="hu-btn hu-btn-primary"><%= heroPrimaryAction.label %></a>
        <a href="/lessons" class="hu-btn hu-btn-outline">Browse lessons</a>
      </div>
      <div class="hu-trust-badge">
        <span class="material-icons" aria-hidden="true">school</span>
        Students, teachers, and admins supported in one platform
      </div>
    </div>

    <div class="hu-hero-visual" aria-label="Platform feature overview">
      <div class="hu-feature-panel">
        <% heroVisualItems.forEach(function(item) { %>
          <a href="<%= item.href %>" class="hu-feature-card" aria-label="<%= item.label %>"<% if (item.target) { %> target="<%= item.target %>" rel="noopener noreferrer"<% } %>>
            <span class="hu-feature-card-icon" aria-hidden="true">
              <span class="material-icons"><%= item.icon %></span>
            </span>
            <span class="hu-feature-card-body">
              <span class="hu-feature-card-name"><%= item.label %></span>
              <span class="hu-feature-card-tag"><%= item.tag %></span>
            </span>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</section>
