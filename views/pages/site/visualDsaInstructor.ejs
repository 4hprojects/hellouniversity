<section class="dsa-shell"><article class="dsa-main" data-instructor-dashboard>
  <nav class="dsa-breadcrumb" aria-label="Breadcrumb"><a href="/visualdsa">VisualDSA</a><span aria-hidden="true">/</span><span>Class analytics</span></nav>
  <header class="dsa-detail-header"><p class="dsa-eyebrow">Instructor analytics</p><h1 data-class-name>VisualDSA class analytics</h1><p>Use learning evidence to identify difficult steps and students who may benefit from support.</p></header>
  <p data-instructor-status aria-live="polite">Loading class analytics…</p>
  <div data-instructor-content hidden>
    <p><a class="visualdsa-button" data-export-link href="#">Export module summary as CSV</a></p>
    <section class="visualdsa-panel" aria-labelledby="publish-assessment-title"><h2 id="publish-assessment-title">Publish a recorded assessment</h2><form class="visualdsa-input-form" data-assignment-form><label>Title<input name="title" minlength="3" maxlength="120" required value="VisualDSA pilot assessment"></label><label>Problem template<select name="templateKey"><option value="array-insert-v1" data-module="arrays">Arrays — insertion</option><option value="stack-operation-sequence-v1" data-module="stacks">Stacks — operation sequence</option><option value="queue-operation-sequence-v1" data-module="queues">Queues — operation sequence</option><option value="binary-search-step-sequence-v1" data-module="binary-search">Binary Search — step sequence</option><option value="bubble-sort-full-trace-v1" data-module="sorting">Bubble Sort — full trace</option><option value="selection-sort-full-trace-v1" data-module="sorting">Selection Sort — full trace</option><option value="insertion-sort-full-trace-v1" data-module="sorting">Insertion Sort — full trace</option><option value="bst-insert-one-v1" data-module="bst">BST — insertion</option><option value="bst-traversal-v1" data-module="bst">BST — traversal</option></select></label><label>Attempt limit<input name="attemptLimit" type="number" min="1" max="5" value="1" required></label><label>Time limit in minutes (0 means none)<input name="timeLimitMinutes" type="number" min="0" max="180" value="30" required></label><label>Opens at (optional)<input name="availableFrom" type="datetime-local"></label><label>Closes at (optional)<input name="availableUntil" type="datetime-local"></label><button type="submit" class="dsa-button dsa-button-primary">Publish assessment</button><p data-assignment-status aria-live="polite"></p></form></section>
    <details class="visualdsa-panel"><summary>How these metrics are calculated</summary><ul><li>Average mastery is the arithmetic mean of current student mastery scores.</li><li>Needs support includes developing and needs-review mastery classifications.</li><li>First-attempt accuracy is correct first responses divided by all first responses.</li><li>Misconceptions count validated server-classified action evidence.</li></ul></details>
    <section class="visualdsa-panel" aria-labelledby="module-summary-title"><h2 id="module-summary-title">Module summary</h2><div class="table-responsive"><table><thead><tr><th scope="col">Module</th><th scope="col">Started</th><th scope="col">Completed</th><th scope="col">Average mastery</th><th scope="col">Needs support</th></tr></thead><tbody data-module-rows></tbody></table></div></section>
    <section class="visualdsa-panel" aria-labelledby="intervention-title"><h2 id="intervention-title">Intervention list</h2><p>Students classified as developing or needing review.</p><div class="table-responsive"><table><thead><tr><th scope="col">Student</th><th scope="col">Module</th><th scope="col">Status</th><th scope="col">Mastery</th></tr></thead><tbody data-intervention-rows></tbody></table></div></section>
    <section class="visualdsa-panel" aria-labelledby="misconception-title"><h2 id="misconception-title">Frequent misconceptions</h2><div class="table-responsive"><table><thead><tr><th scope="col">Module</th><th scope="col">Code</th><th scope="col">Events</th><th scope="col">Students</th></tr></thead><tbody data-misconception-rows></tbody></table></div></section>
    <section class="visualdsa-panel" aria-labelledby="steps-title"><h2 id="steps-title">Most difficult steps</h2><div class="table-responsive"><table><thead><tr><th scope="col">Module</th><th scope="col">Step</th><th scope="col">First-attempt accuracy</th><th scope="col">Responses</th></tr></thead><tbody data-step-rows></tbody></table></div></section>
    <section class="visualdsa-panel" aria-labelledby="student-detail-title" data-student-detail hidden><h2 id="student-detail-title">Student detail</h2><p data-student-detail-status aria-live="polite"></p><div data-student-detail-content></div></section>
  </div>
</article></section>
