<section class="app-page-shell help-page-shell">
    <section class="app-page-header help-page-hero">
        <div class="help-page-copy">
            <p class="help-page-eyebrow">Support Center</p>
            <h1>Help and support for the most common HelloUniversity tasks.</h1>
            <p class="help-page-lead">
                Use this page to get unstuck on account access, lesson discovery, dashboards, search, and common platform workflows without digging through unrelated pages.
            </p>

            <div class="help-page-actions">
                <a href="/search" class="help-page-btn help-page-btn-primary">Search the Site</a>
                <a href="/contact" class="help-page-btn help-page-btn-secondary">Contact Support</a>
            </div>
        </div>

        <aside class="help-page-note">
            <p class="help-page-note-label">Start Here</p>
            <h2>Most common support routes</h2>
            <ul class="help-page-note-list">
                <li><a href="/login">Sign in to your account</a></li>
                <li><a href="/reset-password">Reset a forgotten password</a></li>
                <li><a href="/lessons">Browse lessons and reading tracks</a></li>
                <li><a href="/search">Search lessons, blogs, and public pages</a></li>
            </ul>
        </aside>
    </section>

    <section class="help-page-grid">
        <article class="app-panel help-page-panel">
            <div class="help-page-section-heading">
                <p class="help-page-section-eyebrow">HelloUniversity FAQ</p>
                <h2>Common questions from students, teachers, and schools</h2>
                <p>These answers focus on HelloUniversity account access, classes, quizzes, and academic workflows.</p>
            </div>

            <div class="help-page-faq-list">
                <% helpFaqItems.forEach(function(item, index) { %>
                    <details class="help-page-faq-item"<% if (index === 0) { %> open<% } %>>
                        <summary><%= item.question %></summary>
                        <p><%= item.answer %></p>
                    </details>
                <% }) %>
            </div>
        </article>

        <aside class="app-panel app-panel-muted help-page-panel help-page-support-panel">
            <div class="help-page-section-heading help-page-section-heading-compact">
                <p class="help-page-section-eyebrow">Quick Access</p>
                <h2>Common destinations</h2>
            </div>

            <div class="help-page-link-grid">
                <a href="/login" class="help-page-link-card">
                    <span class="material-icons" aria-hidden="true">login</span>
                    <div>
                        <strong>Sign In</strong>
                        <p>Access your current workspace.</p>
                    </div>
                </a>

                <a href="/signup" class="help-page-link-card">
                    <span class="material-icons" aria-hidden="true">person_add</span>
                    <div>
                        <strong>Create Account</strong>
                        <p>Register as a student or teacher.</p>
                    </div>
                </a>

                <a href="/reset-password" class="help-page-link-card">
                    <span class="material-icons" aria-hidden="true">lock_reset</span>
                    <div>
                        <strong>Reset Password</strong>
                        <p>Recover account access.</p>
                    </div>
                </a>

                <a href="/lessons" class="help-page-link-card">
                    <span class="material-icons" aria-hidden="true">menu_book</span>
                    <div>
                        <strong>Open Lessons</strong>
                        <p>Browse learning content.</p>
                    </div>
                </a>
            </div>
        </aside>
    </section>

    <section class="help-page-section">
        <div class="help-page-section-heading">
            <p class="help-page-section-eyebrow">Common Paths</p>
            <h2>Where users usually need help</h2>
            <p>The support center is strongest when it points users to a clear next step instead of dumping generic text.</p>
        </div>

        <div class="help-page-card-grid">
            <article class="app-panel help-page-card">
                <span class="material-icons help-page-card-icon" aria-hidden="true">badge</span>
                <h3>Account Access</h3>
                <p>Use login, signup, and password reset flows for the account state you are in right now.</p>
            </article>

            <article class="app-panel help-page-card">
                <span class="material-icons help-page-card-icon" aria-hidden="true">library_books</span>
                <h3>Lessons and Reading</h3>
                <p>Go through the lessons catalog when you need structured learning paths instead of isolated article pages.</p>
            </article>

            <article class="app-panel help-page-card">
                <span class="material-icons help-page-card-icon" aria-hidden="true">dashboard</span>
                <h3>Role-Based Workspaces</h3>
                <p>Dashboard access depends on the current user role, so students, teachers, and admins do not share the same landing page.</p>
            </article>

            <article class="app-panel help-page-card">
                <span class="material-icons help-page-card-icon" aria-hidden="true">support_agent</span>
                <h3>Direct Support</h3>
                <p>Use the contact page when the problem is account-specific, blocked by approval, or not covered by the public support content.</p>
            </article>
        </div>
    </section>

    <section class="help-page-grid">
        <article class="app-panel help-page-panel">
            <div class="help-page-section-heading">
                <p class="help-page-section-eyebrow">Reference</p>
                <h2>Grading scale quick reference</h2>
                <p>Where class-record workflows use the 11-point grading scale, these shorthand values are commonly referenced.</p>
            </div>

            <div class="help-page-grade-table-wrap">
                <table class="help-page-grade-table">
                    <thead>
                        <tr>
                            <th scope="col">Grade</th>
                            <th scope="col">Equivalent</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>1.00</td><td>98-100</td></tr>
                        <tr><td>1.25</td><td>95-97</td></tr>
                        <tr><td>1.50</td><td>92-94</td></tr>
                        <tr><td>1.75</td><td>89-91</td></tr>
                        <tr><td>2.00</td><td>86-88</td></tr>
                        <tr><td>2.25</td><td>83-85</td></tr>
                        <tr><td>2.50</td><td>80-82</td></tr>
                        <tr><td>2.75</td><td>77-79</td></tr>
                        <tr><td>3.00</td><td>75-76</td></tr>
                        <tr><td>5.00</td><td>Below 75</td></tr>
                        <tr><td>INC</td><td>Incomplete</td></tr>
                        <tr><td>OD</td><td>Officially Dropped</td></tr>
                        <tr><td>UD</td><td>Unofficially Dropped</td></tr>
                        <tr><td>W</td><td>Withdrawn</td></tr>
                    </tbody>
                </table>
            </div>
        </article>

        <aside class="app-panel help-page-panel help-page-contact-panel">
            <div class="help-page-section-heading help-page-section-heading-compact">
                <p class="help-page-section-eyebrow">Need More Help?</p>
                <h2>Escalate to a direct support path</h2>
            </div>
            <p class="help-page-contact-copy">
                If the issue involves your account, approval state, or a workflow mismatch, use a direct path instead of guessing through the interface.
            </p>
            <div class="help-page-actions help-page-actions-stacked">
                <a href="/contact" class="help-page-btn help-page-btn-primary">Open Contact Page</a>
                <a href="/about" class="help-page-btn help-page-btn-secondary">About the Platform</a>
                <a href="/search" class="help-page-btn help-page-btn-secondary">Search Public Pages</a>
            </div>
        </aside>
    </section>
</section>
