<section class="app-page-shell features-page">
    <section class="features-hero">
        <div class="app-page-header features-hero__content">
            <p class="features-eyebrow">Platform Features</p>
            <h1>What you can do with HelloUniversity before and after login.</h1>
            <p class="features-hero__lead">
                Explore lessons, classes, quizzes, and student tools in one place, with public pages that help you understand the platform before signing in.
            </p>

            <div class="features-hero__actions">
                <a href="/teacher-guide" class="features-btn features-btn--primary">See Teacher Guide</a>
                <a href="/student-guide" class="features-btn features-btn--secondary">See Student Guide</a>
            </div>
        </div>

        <aside class="app-panel app-panel-muted features-hero__aside">
            <p class="features-aside__label">At a glance</p>

            <div class="features-highlight-list">
                <div class="features-highlight-item">
                    <span class="material-icons" aria-hidden="true">school</span>
                    <div>
                        <h3>Made for school use</h3>
                        <p>Built to support teaching, learning, and everyday class activity.</p>
                    </div>
                </div>

                <div class="features-highlight-item">
                    <span class="material-icons" aria-hidden="true">groups</span>
                    <div>
                        <h3>Different views for different users</h3>
                        <p>Teachers, students, and administrators each get tools that fit their work.</p>
                    </div>
                </div>

                <div class="features-highlight-item">
                    <span class="material-icons" aria-hidden="true">visibility</span>
                    <div>
                        <h3>Useful even before login</h3>
                        <p>Visitors can learn about the platform, browse content, and find help pages right away.</p>
                    </div>
                </div>
            </div>
        </aside>
    </section>

    <section class="features-section">
        <div class="features-section__intro">
            <p class="features-section__eyebrow">Core areas</p>
            <h2>What you can do on the platform</h2>
            <p>
                These are the main ways HelloUniversity helps visitors, teachers, and students use the platform more easily.
            </p>
        </div>

        <div class="features-grid">
            <article class="app-panel features-card">
                <div class="features-card__header">
                    <div class="features-card__icon">
                        <span class="material-icons" aria-hidden="true">menu_book</span>
                    </div>
                    <h3>Browse lessons and learning materials</h3>
                </div>
                <p>
                    Visitors can explore lessons and study resources before creating an account.
                </p>
            </article>

            <article class="app-panel features-card">
                <div class="features-card__header">
                    <div class="features-card__icon">
                        <span class="material-icons" aria-hidden="true">co_present</span>
                    </div>
                    <h3>Manage classes and classroom updates</h3>
                </div>
                <p>
                    Teachers can organize classes, post materials, and share announcements in one place.
                </p>
            </article>

            <article class="app-panel features-card">
                <div class="features-card__header">
                    <div class="features-card__icon">
                        <span class="material-icons" aria-hidden="true">quiz</span>
                    </div>
                    <h3>Create and take quizzes</h3>
                </div>
                <p>
                    Teachers can assign quizzes to classes, and students can complete them online.
                </p>
            </article>

            <article class="app-panel features-card">
                <div class="features-card__header">
                    <div class="features-card__icon">
                        <span class="material-icons" aria-hidden="true">fact_check</span>
                    </div>
                    <h3>Check attendance, progress, and grades</h3>
                </div>
                <p>
                    Students can review class activity and academic updates from their student view.
                </p>
            </article>

            <article class="app-panel features-card">
                <div class="features-card__header">
                    <div class="features-card__icon">
                        <span class="material-icons" aria-hidden="true">search</span>
                    </div>
                    <h3>Find the pages you need faster</h3>
                </div>
                <p>
                    Lessons, guides, and support pages are easier to browse and revisit.
                </p>
            </article>

            <article class="app-panel features-card">
                <div class="features-card__header">
                    <div class="features-card__icon">
                        <span class="material-icons" aria-hidden="true">help</span>
                    </div>
                    <h3>Get help and platform information</h3>
                </div>
                <p>
                    Public help, contact, and policy pages make it easier to understand the platform and reach the team.
                </p>
            </article>
        </div>
    </section>

    <section class="features-split">
        <article class="app-panel features-panel">
            <h2>What HelloUniversity is</h2>
            <p>
                HelloUniversity is an academic platform that helps teachers and students work in one connected space. It supports learning, class activity, and everyday school tasks online.
            </p>
        </article>

        <article class="app-panel app-panel-muted features-panel">
            <h2>What you can do before and after login</h2>
            <p>
                You can browse lessons, guides, and support pages now, then access classes, quizzes, attendance, and grades after signing in.
            </p>
        </article>
    </section>

    <section class="features-role-paths">
        <div class="features-section__intro features-section__intro--compact">
            <p class="features-section__eyebrow">Explore by role</p>
            <h2>Choose the guide that fits you</h2>
        </div>

        <div class="features-role-grid">
            <a href="/teacher-guide" class="app-panel features-role-card">
                <div class="features-role-card__icon">
                    <span class="material-icons" aria-hidden="true">cast_for_education</span>
                </div>
                <div class="features-role-card__content">
                    <h3>Teacher Guide</h3>
                    <p>See how teachers can handle classes, lessons, quizzes, and announcements.</p>
                </div>
                <span class="features-role-card__arrow material-icons" aria-hidden="true">arrow_forward</span>
            </a>

            <a href="/student-guide" class="app-panel features-role-card">
                <div class="features-role-card__icon">
                    <span class="material-icons" aria-hidden="true">school</span>
                </div>
                <div class="features-role-card__content">
                    <h3>Student Guide</h3>
                    <p>Learn how students can open lessons, follow class activity, and check attendance and grades.</p>
                </div>
                <span class="features-role-card__arrow material-icons" aria-hidden="true">arrow_forward</span>
            </a>

            <a href="/how-it-works" class="app-panel features-role-card">
                <div class="features-role-card__icon">
                    <span class="material-icons" aria-hidden="true">route</span>
                </div>
                <div class="features-role-card__content">
                    <h3>How It Works</h3>
                    <p>Understand what visitors can access publicly and what becomes available after login.</p>
                </div>
                <span class="features-role-card__arrow material-icons" aria-hidden="true">arrow_forward</span>
            </a>
        </div>
    </section>

    <%- include('../../partials/studyPicksPanel', {
      rootClass: 'study-picks-panel-embedded',
      eyebrow: 'Keep Learning',
      title: 'Study Picks',
      description: 'Move from platform overview into suggested lessons and learning paths you can open right away.',
      catalogHref: '/lessons',
      catalogLabel: 'Open lesson catalog',
      catalogMeta: 'Browse public lessons, review topics, and continue learning without creating an account first.',
      suggestionsAriaLabel: 'Feature page study suggestions',
      openMode: 'same-tab',
      density: 'compact'
    }) %>
</section>
