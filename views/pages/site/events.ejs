<%
  const featuredCollections = Array.isArray(eventFeaturedCollections) ? eventFeaturedCollections : [];
  const catalogEntries = Array.isArray(eventCatalog) ? eventCatalog : [];
  const filterOptions = Array.isArray(eventFilters) ? eventFilters : [];
  const stats = eventStats || { pageCount: 0, collectionCount: 0, resultCount: 0, archiveCount: 0 };
%>

<section class="events-shell">
  <section id="eventsHero" class="events-card events-hero">
    <div class="events-hero-copy">
      <p class="events-eyebrow">Events</p>
      <h1>Browse published event pages and results from past campus activities.</h1>
      <p class="events-subcopy">
        Use this archive to find event details, registration pages, results, and challenge coverage that remain
        available on HelloUniversity.
      </p>
      <div class="events-hero-actions">
        <a href="#eventsCatalog" class="events-btn events-btn-primary">Browse Event Catalog</a>
      </div>
    </div>

    <aside class="events-hero-summary" aria-label="Events archive summary">
      <p class="events-note-label">At a glance</p>
      <div class="events-hero-stats">
        <article class="events-hero-stat">
          <strong><%= stats.pageCount %></strong>
          <span>published pages</span>
        </article>
        <article class="events-hero-stat">
          <strong><%= stats.collectionCount %></strong>
          <span>featured collections</span>
        </article>
        <article class="events-hero-stat">
          <strong><%= stats.resultCount %></strong>
          <span>results pages</span>
        </article>
      </div>
    </aside>
  </section>

  <% if (featuredCollections.length) { %>
    <section id="eventCollections" class="events-card events-panel">
      <div class="events-section-heading">
        <p class="events-eyebrow">Featured Collections</p>
        <h2>Quick paths into the main event sets</h2>
        <p class="events-meta">Start here if you already know the series you want to open.</p>
      </div>

      <div class="events-collection-grid">
        <% featuredCollections.forEach(function(collection) { %>
          <article class="events-collection-card">
            <div class="events-collection-top">
              <div>
                <p class="events-collection-eyebrow"><%= collection.eyebrow %></p>
                <h3><%= collection.title %></h3>
              </div>
              <span class="events-collection-count"><%= collection.pageCount %> pages</span>
            </div>
            <p class="events-meta events-collection-date"><%= collection.dateLabel %></p>
            <p class="events-collection-summary"><%= collection.summary %></p>
            <div class="events-collection-links">
              <% collection.links.forEach(function(link) { %>
                <a href="<%= link.href %>" class="events-collection-link"><%= link.label %></a>
              <% }) %>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section id="eventsCatalog" class="events-card events-panel">
    <div class="events-section-heading">
      <p class="events-eyebrow">Catalog</p>
      <h2>Search and filter the available event pages</h2>
      <p class="events-meta">The catalog below keeps the archive simple: search, filter, open the page you need.</p>
    </div>

    <div class="events-filter-toolbar">
      <div class="events-search-field">
        <label for="eventsCatalogSearch">Search event titles, page types, or venues</label>
        <input
          id="eventsCatalogSearch"
          class="events-search-input"
          type="search"
          placeholder="Search quiz bee, fun run, results, challenge..."
          autocomplete="off">
      </div>
      <button id="eventsClearFilters" type="button" class="events-btn events-btn-secondary">Clear Filters</button>
    </div>

    <div class="events-filter-bar" role="toolbar" aria-label="Event page filters">
      <% filterOptions.forEach(function(filter, index) { %>
        <button
          type="button"
          class="events-filter-chip <%= index === 0 ? 'events-filter-chip-active' : '' %>"
          data-events-filter="<%= filter.value %>"
          aria-pressed="<%= index === 0 ? 'true' : 'false' %>">
          <%= filter.label %>
        </button>
      <% }) %>
    </div>

    <p id="eventsResultsLabel" class="events-results-label" aria-live="polite">
      Showing all <%= stats.pageCount %> event pages
    </p>

    <div class="events-card-grid">
      <% catalogEntries.forEach(function(item) { %>
        <article
          class="events-item-card"
          data-event-card
          data-type="<%= item.type %>"
          data-search="<%= item.searchText %>">
          <div class="events-item-top">
            <div>
              <p class="events-item-series"><%= item.series %></p>
              <h3><a href="<%= item.href %>"><%= item.title %></a></h3>
            </div>
            <span class="events-item-type"><%= item.typeLabel %></span>
          </div>

          <p class="events-item-summary"><%= item.summary %></p>

          <div class="events-item-meta">
            <span><%= item.dateLabel %></span>
            <span><%= item.venue %></span>
          </div>

          <div class="events-item-footer">
            <a href="<%= item.href %>" class="events-inline-link"><%= item.ctaLabel %></a>
          </div>
        </article>
      <% }) %>
    </div>

    <div id="eventsEmptyState" class="events-empty-state" hidden>
      <span class="material-icons" aria-hidden="true">event_busy</span>
      <h3>No event pages match the current filters</h3>
      <p>Try a broader search or reset the filters to bring the full catalog back.</p>
    </div>
  </section>
</section>
