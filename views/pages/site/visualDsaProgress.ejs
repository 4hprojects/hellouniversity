<section class="dsa-shell"><article class="dsa-main" data-visualdsa-progress>
  <nav class="dsa-breadcrumb" aria-label="Breadcrumb"><a href="/visualdsa">VisualDSA</a><span aria-hidden="true">/</span><span>My Progress</span></nav>
  <header class="dsa-detail-header"><p class="dsa-eyebrow">Student analytics</p><h1>My VisualDSA Progress</h1><p>Review evidence from your own practice and recorded assessments.</p></header>
  <p data-progress-status aria-live="polite">Loading your progress…</p>
  <section class="visualdsa-panel" data-progress-next hidden><p class="dsa-eyebrow">Your next step</p><div data-progress-next-content></div></section>
  <div class="visualdsa-detail-grid" data-progress-content hidden>
    <section class="visualdsa-panel"><h2>Current course</h2><div data-progress-course></div></section>
    <section class="visualdsa-panel"><h2>Assigned activities</h2><div data-progress-assignments></div></section>
    <section class="visualdsa-panel"><h2>Topic mastery</h2><div data-progress-mastery></div></section>
    <section class="visualdsa-panel"><h2>Recommended review</h2><div data-progress-recommendations></div></section>
    <section class="visualdsa-panel"><h2>Common personal errors</h2><div data-progress-misconceptions></div></section>
    <section class="visualdsa-panel"><h2>Practice history</h2><div data-progress-practice></div></section>
    <section class="visualdsa-panel"><h2>Assessment history</h2><div data-progress-assessments></div></section>
    <section class="visualdsa-panel"><h2>Recent activity</h2><div data-progress-recent></div></section>
  </div>
  <section class="visualdsa-panel" data-assessment-workspace hidden aria-labelledby="assessmentWorkspaceTitle">
    <h2 id="assessmentWorkspaceTitle">Recorded assessment</h2>
    <p data-assessment-status aria-live="polite"></p>
    <p><strong>Time remaining:</strong> <span data-assessment-timer>Not limited</span>. Responses are saved after each submission and correctness remains hidden until final grading.</p>
    <div data-assessment-problem></div>
    <form data-assessment-response hidden><label><span data-assessment-prompt>Enter your response.</span><input name="response" required autocomplete="off"></label><button type="submit" class="dsa-button dsa-button-primary">Submit response</button></form>
    <div data-assessment-review hidden></div>
    <button type="button" class="dsa-button dsa-button-primary" data-assessment-submit hidden>Submit assessment for grading</button>
  </section>
</article></section>
