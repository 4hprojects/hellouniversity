<section
  class="student-shell student-dashboard-page"
  id="studentDashboardPage"
  data-student-name="<%= studentDisplayName || 'Student' %>"
  data-student-id="<%= studentIDNumber || '' %>"
  data-student-role="<%= studentRole || 'student' %>">
  <section class="dashboard-overview-layout">
    <section class="student-card dashboard-overview">
      <div class="dashboard-overview-copy">
        <p class="student-eyebrow">Student Dashboard</p>
        <h1>Hello, <span id="studentDisplayName"><%= studentDisplayName || 'Student' %></span>.</h1>
        <p class="student-subcopy">Start with what needs attention, open your classes quickly, and review your latest academic snapshot in one clean workspace.</p>
      </div>

      <section class="dashboard-kpi-list" aria-label="Student overview">
        <a href="/classes" class="dashboard-kpi-list-item dashboard-kpi-list-link">
          <p class="student-kpi-label">Joined Classes</p>
          <p id="studentJoinedClassCount" class="student-kpi-value">-</p>
          <p id="studentJoinedClassMeta" class="student-meta">Loading class summary...</p>
        </a>
        <a href="/activities" class="dashboard-kpi-list-item dashboard-kpi-list-link">
          <p class="student-kpi-label">Open Activities</p>
          <p id="studentOpenActivityCount" class="student-kpi-value">-</p>
          <p id="studentOpenActivityMeta" class="student-meta">Loading activity summary...</p>
        </a>
        <a href="/activities" class="dashboard-kpi-list-item dashboard-kpi-list-link">
          <p class="student-kpi-label">Overdue Work</p>
          <p id="studentOverdueCount" class="student-kpi-value">-</p>
          <p id="studentOverdueMeta" class="student-meta">Loading overdue status...</p>
        </a>
      </section>

      <details id="studentJoinClassDetails" class="dashboard-join-card dashboard-join-card-collapsible">
        <summary class="dashboard-join-toggle">
          <div class="dashboard-join-copy">
            <p class="student-eyebrow">Join a Class</p>
            <h3>Use your teacher&apos;s class code</h3>
            <p class="student-meta">Join directly from the dashboard without leaving this page.</p>
          </div>
          <span class="material-icons dashboard-join-toggle-icon" aria-hidden="true">expand_more</span>
        </summary>

        <div class="dashboard-join-content">
          <form id="studentJoinClassForm" class="student-join-form dashboard-join-form">
            <div class="student-join-form-row dashboard-join-form-row">
              <input
                id="studentJoinClassCode"
                class="student-input"
                type="text"
                name="classCode"
                placeholder="Enter class code"
                inputmode="text"
                autocomplete="off"
                maxlength="32"
                aria-label="Class code">
              <button id="studentJoinClassButton" type="submit" class="student-btn student-btn-primary">Join class</button>
            </div>
          </form>

          <div
            id="studentJoinClassStatus"
            class="student-status student-status-info"
            role="status"
            aria-live="polite"
            hidden
          ></div>
        </div>
      </details>
    </section>

    <article class="student-card dashboard-focus-card">
      <div class="student-panel-header">
        <div>
          <p class="student-eyebrow">Notifications</p>
          <h2>What needs your attention</h2>
        </div>
      </div>

      <div id="studentAttentionList" class="dashboard-attention-list">
        <p class="student-empty-state">Loading notifications...</p>
      </div>
    </article>
  </section>

  <section class="student-dashboard-grid dashboard-main-grid dashboard-utility-grid">
    <div class="student-panel-stack dashboard-utility-stack">
      <article class="student-card student-panel" id="studentJoinClassCard">
        <div class="student-panel-header">
          <div>
            <p class="student-eyebrow">Quick Access</p>
            <h2>Student Tools</h2>
          </div>
        </div>

        <div class="student-shortcuts dashboard-shortcuts dashboard-shortcuts-primary">
          <a href="/play" class="student-shortcut dashboard-primary-shortcut dashboard-primary-shortcut-tile">
            <span class="material-icons" aria-hidden="true">sports_esports</span>
            <span class="dashboard-primary-shortcut-copy">
              <span class="student-shortcut-label">ClassRush</span>
              <span class="dashboard-primary-shortcut-meta">Jump into the classroom challenge space.</span>
            </span>
          </a>
          <a href="/blogs/new" class="student-shortcut dashboard-primary-shortcut dashboard-primary-shortcut-tile">
            <span class="material-icons" aria-hidden="true">edit_square</span>
            <span class="dashboard-primary-shortcut-copy">
              <span class="student-shortcut-label">Write a Blog</span>
              <span class="dashboard-primary-shortcut-meta">Start a draft and submit your ideas.</span>
            </span>
          </a>
        </div>

        <%- include('../../partials/studyPicksPanel', {
          rootClass: 'study-picks-panel-embedded',
          eyebrow: 'Browse Lessons',
          title: 'Study Picks',
          description: 'Open the lesson catalog or jump straight into a suggested lesson or book.',
          catalogHref: '/lessons',
          catalogLabel: 'Open lesson catalog',
          catalogMeta: 'Browse tracks, review topics, and choose your next study path.',
          suggestionsAriaLabel: 'Student study suggestions',
          openMode: 'new-tab',
          density: 'compact'
        }) %>

      </article>
    </div>
  </section>
</section>
