<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title><%= title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/ustyles.css">
  <link rel="stylesheet" href="/dist/output.css">
</head>
<body class="bg-gray-50">
  <%- include('../partials/nav') %>
  <main class="max-w-3xl mx-auto p-6">
    <h1 id="quizTitle" class="text-2xl font-semibold mb-4">Loading...</h1>
    <form id="quizForm" class="space-y-4"></form>
    <div class="mt-4 flex gap-3">
      <button id="submitBtn" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700" type="button">Submit</button>
      <span id="status" class="text-sm text-gray-600"></span>
    </div>
    <div id="result" class="mt-6 text-lg font-semibold"></div>
  </main>
  <script>
    window.__QUIZ_ID__ = "<%= quizId %>";
  </script>
  <script src="/js/quizzes/player.js"></script>
</body>
</html>
