<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title><%= title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/ustyles.css">
  <link rel="stylesheet" href="/css/quiz.css">
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="quiz-form-container">
    <h1 id="quizTitle" class="quiz-form-title">Loading...</h1>
    <form id="quizForm" class="quiz-form-stack"></form>
    <div style="margin-top:1rem; display:flex; gap:0.75rem; align-items:center;">
      <button id="submitBtn" class="quiz-submit-btn" type="button">Submit</button>
      <span id="status" class="quiz-status"></span>
    </div>
    <div id="result" class="quiz-result"></div>
  </main>
  <script>
    window.__QUIZ_ID__ = "<%= quizId %>";
  </script>
  <script src="/js/quizzes/player.js"></script>
</body>
</html>
