<!DOCTYPE html>
<html lang="en" style="scroll-behavior: smooth;">
<%- include('../partials/head', {
  title: (typeof title !== 'undefined' ? title : undefined),
  description: (typeof description !== 'undefined' ? description : undefined),
  canonicalUrl: (typeof canonicalUrl !== 'undefined' ? canonicalUrl : undefined),
  includeAppTheme: false,
  stylesheets: (typeof stylesheets !== 'undefined' ? stylesheets : undefined),
  extraHead: (typeof extraHead !== 'undefined' ? extraHead : undefined)
}) %>
<%
  const hasAppShellNav = typeof appShellNav !== 'undefined' && appShellNav;
  const shouldShowCrfvNav = typeof showCrfvNav === 'undefined' || showCrfvNav !== false;
%>
<body class="crfv-layout <%= typeof pageClass === 'string' ? pageClass : '' %> <%= hasAppShellNav ? 'has-crfv-app-nav' : (shouldShowCrfvNav ? 'has-crfv-public-nav' : '') %>">
  <% if (hasAppShellNav) { %>
    <div class="crfv-app-shell">
      <%- include('../partials/crfv/app-shell-nav', { appShellNav: appShellNav }) %>
      <main id="mainContent" class="crfv-app-shell__main">
        <div class="crfv-app-shell__content">
          <%- body %>
        </div>
      </main>
      <%- include('../partials/crfv/footer') %>
    </div>
  <% } else { %>
    <% if (shouldShowCrfvNav) { %>
    <header class="crfv-app-nav">
      <div class="crfv-app-nav__bar">
        <%- include('../partials/crfv/menu') %>
        <div class="crfv-app-nav__right">
          <div class="crfv-app-nav__title">CRFV Event System</div>
        </div>
      </div>
    </header>
    <% } %>
    <main id="mainContent">
      <%- body %>
    </main>
  <% } %>

  <% if (Array.isArray(typeof scriptUrls !== 'undefined' ? scriptUrls : undefined)) { %>
    <% scriptUrls.forEach(function(src) { %>
      <script src="<%= src %>"></script>
    <% }) %>
  <% } %>

  <% if (Array.isArray(typeof deferScriptUrls !== 'undefined' ? deferScriptUrls : undefined)) { %>
    <% deferScriptUrls.forEach(function(src) { %>
      <script src="<%= src %>" defer></script>
    <% }) %>
  <% } %>

  <%- typeof extraScripts === 'string' ? extraScripts : '' %>
</body>
</html>
